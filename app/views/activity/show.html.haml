- content_for :title, "Activity — EmuVault"

.p-4.lg:p-6.max-w-3xl
  = render ::UI::PageHeaderComponent.new(title: "Activity", subtitle: "Recent uploads and downloads")

  - if @games.any? || @events.any?
    .mb-4
      = form_with url: activity_path, method: :get, data: { controller: "auto-submit" } do
        .flex.items-center.gap-2.flex-wrap
          - if @games.any?
            = select_tag :game_id, options_for_select([["All games", ""], *@games.map { |g| [g.title, g.id] }], @selected_game_id), class: "rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2 cursor-pointer focus:outline-none focus:border-drac-cyan", data: { action: "change->auto-submit#submit" }
          = select_tag :sort, options_for_select([["Newest first", "newest"], ["Oldest first", "oldest"]], @selected_sort), class: "rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2 cursor-pointer focus:outline-none focus:border-drac-cyan", data: { action: "change->auto-submit#submit" }
          - if @selected_game_id.present?
            = link_to activity_path(sort: @selected_sort), class: "text-xs text-drac-comment hover:text-drac-fg transition-colors inline-flex items-center gap-1" do
              %i.fa-solid.fa-xmark
              Clear

  - if @events.empty?
    = render ::UI::EmptyStateComponent.new(title: "No activity yet", description: "Uploads and downloads will appear here.")

  - elsif @selected_game_id
    -# Filtered: flat chronological list for one game
    .rounded-lg.bg-drac-bg.border.border-drac-current.divide-y.divide-drac-current
      - @events.each do |event|
        .flex.items-center.gap-4.px-5.py-4
          .flex-1.min-w-0
            .flex.items-center.gap-2.mb-1
              = render ::UI::BadgeComponent.new(label: event.action_label, color: event.action_badge_color)
              = render ::UI::BadgeComponent.new(label: event.device_label, color: event.device_badge_color)
            %p.text-xs.text-drac-comment= event.performed_at_label
          - if event.ip_address.present?
            %span.text-xs.text-drac-comment.font-mono.hidden.lg:block= event.ip_address

  - else
    -# Unfiltered: grouped by game
    .space-y-3
      - @events.group_by { |e| [e.game_id, e.game_title] }.each do |(gid, gtitle), events|
        .rounded-lg.bg-drac-bg.border.border-drac-current.overflow-hidden
          .px-5.py-3.border-b.border-drac-current
            = link_to gtitle, game_path(gid), class: "text-sm font-semibold text-drac-purple hover:underline cursor-pointer"
          .divide-y.divide-drac-current
            - events.each do |event|
              .flex.items-center.gap-4.px-5.py-3
                .flex-1.min-w-0
                  .flex.items-center.gap-2
                    = render ::UI::BadgeComponent.new(label: event.action_label, color: event.action_badge_color)
                    = render ::UI::BadgeComponent.new(label: event.device_label, color: event.device_badge_color)
                    %span.text-xs.text-drac-comment= event.performed_at_label
                - if event.ip_address.present?
                  %span.text-xs.text-drac-comment.font-mono.hidden.lg:block= event.ip_address
