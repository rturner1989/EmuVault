= simple_form_for @form, url: form_url, html: { class: "space-y-5" } do |f|
  = f.input :name,
      label: "Name",
      input_html: { class: "mt-1 block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg px-3 py-2 text-sm focus:border-drac-purple focus:outline-none" },
      label_html: { class: "block text-sm font-medium text-drac-fg" }

  = f.input :device_type,
      label: "Type",
      as: :select,
      collection: Device.device_type.values,
      value_method: :value,
      label_method: :text,
      include_blank: "— select a type —",
      input_html: { class: "mt-1 block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg px-3 py-2 text-sm focus:border-drac-purple focus:outline-none" },
      label_html: { class: "block text-sm font-medium text-drac-fg" }

  = f.input :identifier,
      label: "Identifier (optional)",
      hint: "A unique ID for this device, e.g. a Tailscale node name.",
      input_html: { class: "mt-1 block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg px-3 py-2 text-sm font-mono focus:border-drac-purple focus:outline-none" },
      label_html: { class: "block text-sm font-medium text-drac-fg" },
      hint_html: { class: "mt-1 text-xs text-drac-comment" }

  .flex.items-center.gap-3.pt-2
    = f.button :submit, submit_label, class: "rounded-lg bg-drac-purple px-5 py-2 text-sm font-medium text-drac-bg hover:opacity-90 transition-opacity"
    = link_to "Cancel", cancel_path, class: "text-sm text-drac-comment hover:text-drac-fg"
