- content_for :title, "Devices — EmuVault"

.p-6
  = render ::UI::PageHeaderComponent.new(title: "Devices", subtitle: "#{@devices.size} device#{'s' unless @devices.size == 1}") do |header|
    - header.with_action do
      = link_to "Add Device", new_device_path, class: "rounded-lg bg-drac-purple px-4 py-2 text-sm font-medium text-drac-bg hover:opacity-90 transition-opacity"

  - if @devices.empty?
    = render ::UI::EmptyStateComponent.new(title: "No devices yet", description: "Register a device to track sync history per device.") do |c|
      - c.with_action do
        = link_to "Add Device", new_device_path, class: "rounded-lg bg-drac-purple px-4 py-2 text-sm font-medium text-drac-bg hover:opacity-90"
  - else
    .rounded-lg.bg-drac-bg.border.border-drac-current.overflow-hidden
      %table.min-w-full.divide-y.divide-drac-current
        %thead
          %tr
            %th.px-5.py-3.text-left.text-xs.font-semibold.text-drac-comment.uppercase.tracking-wide Name
            %th.px-5.py-3.text-left.text-xs.font-semibold.text-drac-comment.uppercase.tracking-wide Type
            %th.px-5.py-3.text-left.text-xs.font-semibold.text-drac-comment.uppercase.tracking-wide Last Seen
            %th.px-5.py-3
        %tbody.divide-y.divide-drac-current
          - @devices.each do |device|
            %tr.hover:bg-drac-current.transition-colors
              %td.px-5.py-3
                = link_to device.name, device_path(device), class: "text-sm font-medium text-drac-fg hover:text-drac-purple"
              %td.px-5.py-3
                = render ::UI::BadgeComponent.new(label: device.type_label, color: device.type_badge_color)
              %td.px-5.py-3.text-sm.text-drac-comment= device.last_seen_label
              %td.px-5.py-3.text-right.whitespace-nowrap
                = link_to "Edit", edit_device_path(device), class: "text-xs text-drac-comment hover:text-drac-fg mr-3"
                = button_to "Remove", device_path(device), method: :delete, data: { turbo_confirm: "Remove #{device.name}?" }, class: "text-xs text-drac-red hover:opacity-80"
