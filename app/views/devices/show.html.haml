- content_for :title, "#{@device.name} — EmuVault"

.p-6
  = render ::UI::PageHeaderComponent.new(title: @device.name) do |header|
    - header.with_action do
      = link_to "Edit", edit_device_path(@device), class: "rounded-lg border border-drac-current px-4 py-2 text-sm font-medium text-drac-fg hover:bg-drac-current transition-colors"
    - header.with_action do
      = button_to "Remove", device_path(@device), method: :delete, data: { turbo_confirm: "Remove #{@device.name}?" }, class: "rounded-lg border border-drac-red px-4 py-2 text-sm font-medium text-drac-red hover:bg-drac-red/10 transition-colors"

  .rounded-lg.bg-drac-bg.border.border-drac-current.p-5.mb-6
    .grid.grid-cols-2.gap-4.sm:grid-cols-3
      .space-y-1
        .text-xs.text-drac-comment Type
        = render ::UI::BadgeComponent.new(label: @device.type_label, color: @device.type_badge_color)
      .space-y-1
        .text-xs.text-drac-comment Last Seen
        .text-sm.text-drac-fg= @device.last_seen_label
      - if @device.identifier.present?
        .space-y-1
          .text-xs.text-drac-comment Identifier
          .text-sm.text-drac-fg.font-mono.truncate= @device.identifier

  .rounded-lg.bg-drac-bg.border.border-drac-current
    .px-5.py-4.border-b.border-drac-current
      %h2.text-sm.font-semibold.text-drac-fg Sync History
    .px-5.py-8.text-center.text-sm.text-drac-comment No sync activity yet.
