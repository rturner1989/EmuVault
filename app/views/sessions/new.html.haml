- content_for :title, t(".page_title")

.h-screen.flex.items-center.justify-center.overflow-hidden.bg-base-200
  .w-full.max-w-sm.px-4
    .text-center.mb-8
      .flex.justify-center
        = render ::UI::LogoComponent.new(size: :lg)
      %p.mt-2.text-sm.text-muted
        = t(".heading")

    = render ::UI::CardComponent.new do |c|
      - c.with_body do
        = simple_form_for :session, url: session_path, method: :post, html: { class: "space-y-4" } do |f|
          = f.input :username,
            label: t(".username"),
            required: true,
            input_html: { autocomplete: "username", required: true, class: "input input-bordered w-full" },
            label_html: { class: "label-text font-medium" }
          = f.input :password,
            as: :password,
            label: t(".password"),
            required: true,
            input_html: { autocomplete: "current-password", required: true, class: "input input-bordered w-full" },
            label_html: { class: "label-text font-medium" }
          = render ::UI::ActionComponent.new(variant: :primary,
            type: :submit,
            class: "w-full mt-2") do
            = t(".sign_in")
