- content_for :title, "Sign in — EmuVault"

.h-screen.flex.items-center.justify-center.overflow-hidden{ class: "bg-base-200" }
  .w-full.max-w-sm.px-4
    .text-center.mb-8
      .flex.justify-center
        = render ::UI::LogoComponent.new(size: :lg)
      %p.mt-2.text-sm.text-muted Sign in to your vault

    - if notice
      %div{ class: "mb-4 alert alert-success" }= notice
    - if alert
      %div{ class: "mb-4 alert alert-error" }= alert

    = render ::UI::CardComponent.new do |c|
      - c.with_body do
        = simple_form_for :session, url: session_path, method: :post, html: { class: "space-y-4" } do |f|
          = f.input :email_address,
              label: "Email",
              input_html: { autocomplete: "email", class: "input input-bordered w-full" },
              label_html: { class: "label-text font-medium" }
          = f.input :password,
              as: :password,
              label: "Password",
              input_html: { autocomplete: "current-password", class: "input input-bordered w-full" },
              label_html: { class: "label-text font-medium" }
          = f.button :submit, "Sign in", class: "btn btn-primary w-full mt-2"
