- content_for :title, "Sign in — EmuVault"

.min-h-screen.flex.items-center.justify-center.bg-drac-surface
  .w-full.max-w-sm.px-4
    .text-center.mb-8
      %h1.text-3xl.font-bold.text-drac-purple EmuVault
      %p.mt-2.text-sm.text-drac-comment Sign in to your vault

    - if notice
      %div{ class: "mb-4 rounded-lg border border-drac-green bg-drac-green/10 p-3 text-sm text-drac-green" }= notice
    - if alert
      %div{ class: "mb-4 rounded-lg border border-drac-red bg-drac-red/10 p-3 text-sm text-drac-red" }= alert

    .rounded-lg.bg-drac-bg.border.border-drac-current.p-6
      = simple_form_for :session, url: session_path, method: :post, html: { class: "space-y-4" } do |f|
        = f.input :email_address,
            label: "Email",
            input_html: { autocomplete: "email", class: "mt-1 block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg px-3 py-2 text-sm focus:border-drac-purple focus:outline-none" },
            label_html: { class: "block text-sm font-medium text-drac-fg" }
        = f.input :password,
            as: :password,
            label: "Password",
            input_html: { autocomplete: "current-password", class: "mt-1 block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg px-3 py-2 text-sm focus:border-drac-purple focus:outline-none" },
            label_html: { class: "block text-sm font-medium text-drac-fg" }
        = f.button :submit, "Sign in", class: "mt-2 w-full rounded-lg bg-drac-purple px-4 py-2 text-sm font-medium text-drac-bg hover:opacity-90 transition-opacity"
