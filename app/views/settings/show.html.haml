- content_for :title, "Settings — EmuVault"

.p-4.lg:p-6.max-w-2xl.space-y-4.overflow-x-hidden
  = render ::UI::PageHeaderComponent.new(title: "Settings")

  .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
    %h2.text-sm.font-semibold.text-drac-fg.mb-1 Account
    %p.text-sm.text-drac-comment.mb-4= @user.email_address
    .flex.items-center.gap-3
      = render ::UI::ModalComponent.new(id: "change-password-dialog", title: "Change Password") do |modal|
        = modal.with_trigger do
          = render ::UI::ActionComponent.new(label: "Change Password", variant: :secondary, data: { action: "dialog#open" })
        = modal.with_body do
          = render "passwords/form"
      = button_to "Sign Out", session_path, method: :delete, form: { data: { turbo: false } }, class: "px-3 py-1.5 rounded-lg text-sm font-medium text-drac-red border border-drac-red/40 hover:bg-drac-red/10 transition-colors cursor-pointer"

  .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
    %h2.text-sm.font-semibold.text-drac-fg.mb-1 Monitoring
    %p.text-sm.text-drac-comment.mb-4 Internal dashboards — admin credentials required.
    .space-y-2
      = link_to "/pghero", target: "_blank", class: "flex items-center justify-between rounded-lg border border-drac-current px-4 py-3 hover:border-drac-purple transition-colors group" do
        .min-w-0
          %p.text-sm.font-medium.text-drac-fg PgHero
          %p.text-xs.text-drac-comment Database performance — slow queries, index usage, table sizes
        %i.fa-solid.fa-arrow-up-right-from-square.text-drac-comment.group-hover:text-drac-purple.transition-colors.shrink-0.ml-3
      = link_to "/sidekiq", target: "_blank", class: "flex items-center justify-between rounded-lg border border-drac-current px-4 py-3 hover:border-drac-purple transition-colors group" do
        .min-w-0
          %p.text-sm.font-medium.text-drac-fg Sidekiq
          %p.text-xs.text-drac-comment Background job queues, failures, and throughput
        %i.fa-solid.fa-arrow-up-right-from-square.text-drac-comment.group-hover:text-drac-purple.transition-colors.shrink-0.ml-3
      .flex.items-center.justify-between.rounded-lg.border.border-drac-current.px-4.py-3
        .min-w-0
          %p.text-sm.font-medium.text-drac-fg Uptime Kuma
          %p.text-xs.text-drac-comment
            Run as a standalone app on your server. Monitor EmuVault at
            %span.font-mono.break-all= "#{request.host}/up"

  .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
    %h2.text-sm.font-semibold.text-drac-fg.mb-1 Library Scan
    %p.text-sm.text-drac-comment.mb-4 Point EmuVault at your games directories. It will discover new games and any save files alongside them.

    -# Last scan result
    - result = @user.last_scan_result
    - if result.present? && result["status"] == "completed"
      .rounded-lg.border.border-drac-current.px-4.py-3.mb-4
        %p.text-xs.text-drac-comment.mb-1 Last scan
        %p.text-sm.text-drac-fg
          Added #{result["added"]} #{pluralize(result["added"].to_i, "game")}
          — #{result["skipped"] || 0} already in library
        - if result["errors"]&.any?
          %p.text-xs.mt-1{ class: "text-drac-red" }= "#{result["errors"].size} errors"
        %p.text-xs.text-drac-comment.mt-1= @user.last_scanned_at&.strftime("%d %b %Y at %H:%M")

    -# Scan actions
    .flex.items-center.gap-3.mb-5
      = button_to library_scan_path, method: :post, class: "px-3 py-1.5 bg-drac-purple text-drac-bg font-medium rounded-lg text-sm hover:opacity-90 transition-opacity cursor-pointer" do
        %i.fa-solid.fa-magnifying-glass.mr-1
        Scan now
      - if result.present? && result["status"] == "pending_review"
        = link_to review_library_scan_path, class: "px-3 py-1.5 rounded-lg border border-drac-yellow text-drac-yellow text-sm hover:opacity-80 transition-opacity" do
          %i.fa-solid.fa-eye.mr-1
          Review (#{(result["found"] || []).size} found)

    = turbo_frame_tag "scan_paths" do
      -# Configured scan paths
      - if @scan_paths.any?
        .rounded-lg.border.border-drac-current.overflow-hidden.mb-4
          .divide-y.divide-drac-current
            - @scan_paths.each do |sp|
              .flex.items-center.gap-3.px-4.py-3
                .flex-1.min-w-0
                  %p.text-sm.text-drac-fg.font-mono.truncate= sp.path
                  %p.text-xs.text-drac-comment= sp.game_system.text
                = button_to scan_path_path(sp), method: :patch, params: { scan_path: { auto_scan: !sp.auto_scan } }, class: "shrink-0 text-xs px-2 py-1 rounded border transition-colors cursor-pointer #{sp.auto_scan ? 'border-drac-purple text-drac-purple' : 'border-drac-current text-drac-comment hover:border-drac-fg hover:text-drac-fg'}" do
                  %i.fa-solid.fa-rotate.mr-1
                  = sp.auto_scan ? "Auto-scan on" : "Auto-scan off"
                = button_to scan_path_path(sp), method: :delete, class: "shrink-0 text-drac-comment hover:text-drac-red transition-colors cursor-pointer px-2 py-1" do
                  %i.fa-solid.fa-trash

      -# Add path modal
      = render "scan_paths/add_modal"

    -# Auto-scan schedule
    .border-t.border-drac-current.mt-5.pt-5
      %p.text-sm.font-medium.text-drac-fg.mb-3 Auto-scan schedule
      = form_with model: @user, url: settings_path, method: :patch, html: { class: "space-y-3" } do |f|
        .flex.items-center.justify-between
          .min-w-0
            %p.text-sm.text-drac-fg Enable auto-scan
            %p.text-xs.text-drac-comment Paths marked "auto-scan on" will be scanned automatically
          = f.check_box :scan_enabled, class: "accent-drac-purple w-4 h-4 cursor-pointer shrink-0 ml-4"
        .flex.items-center.justify-between
          %label.text-sm.text-drac-fg{ for: "user_scan_interval" } Interval
          = f.select :scan_interval, User.scan_interval.values.map { |v| [v.text, v.value] }, {}, class: "bg-drac-surface border border-drac-current rounded-lg px-3 py-1.5 text-sm text-drac-fg"
        = f.submit "Save", class: "px-3 py-1.5 rounded-lg border border-drac-current text-sm text-drac-comment hover:border-drac-fg hover:text-drac-fg transition-colors cursor-pointer"

  .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
    %h2.text-sm.font-semibold.text-drac-fg.mb-1 Data
    %p.text-sm.text-drac-comment.mb-4 Export your games and save files, or restore from a previous export.
    .space-y-4
      .flex.items-center.justify-between
        .min-w-0
          %p.text-sm.font-medium.text-drac-fg Export library
          %p.text-xs.text-drac-comment Downloads all games and save files as a ZIP archive
        = button_to "Export", data_exports_path, method: :post, form: { data: { turbo: false } }, class: "ml-4 shrink-0 px-3 py-1.5 bg-drac-purple text-drac-bg font-medium rounded-lg text-sm hover:opacity-90 transition-opacity cursor-pointer"
      .border-t.border-drac-current.pt-4
        = form_with url: data_imports_path, multipart: true do |f|
          .flex.items-center.justify-between.mb-3
            .min-w-0
              %p.text-sm.font-medium.text-drac-fg Import library
              %p.text-xs.text-drac-comment Restore from a previous EmuVault export ZIP
          .flex.items-center.gap-3.min-w-0
            = f.file_field :file, accept: ".zip", class: "w-0 flex-1 min-w-0 text-sm text-drac-comment file:mr-3 file:px-3 file:py-1.5 file:rounded-lg file:border-0 file:bg-drac-current file:text-drac-fg file:text-sm file:cursor-pointer hover:file:opacity-80 transition-opacity"
            = f.submit "Import", class: "shrink-0 px-3 py-1.5 bg-drac-cyan text-drac-bg font-medium rounded-lg text-sm hover:opacity-90 transition-opacity cursor-pointer"

  .rounded-lg.bg-drac-bg.border.border-drac-current.p-5{ data: { controller: "push-subscription", "push-subscription-vapid-public-key-value": ENV["VAPID_PUBLIC_KEY"].to_s } }
    %h2.text-sm.font-semibold.text-drac-fg.mb-1 Push Notifications
    %p.text-sm.text-drac-comment.mb-4 Get notified on this device when a new save is uploaded. Works when EmuVault is installed as a home screen app.
    %button.px-3.py-1.5.rounded-lg.text-sm.bg-drac-purple.text-white.hover:opacity-90.transition-opacity{ data: { action: "push-subscription#subscribe", "push-subscription-target": "button" } }
      Enable push notifications
    %p.text-xs.text-drac-comment.mt-2{ data: { "push-subscription-target": "status" } }
