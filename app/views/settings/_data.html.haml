= render ::UI::CardComponent.new do |card|
  = card.with_header do
    %h2.text-sm.font-semibold.mb-1
      = t(".title")
    %p.text-sm.text-muted
      = t(".description")

  = card.with_body do
    .space-y-4
      .flex.items-center.justify-between
        .min-w-0
          %p.text-sm.font-medium
            = t(".export_title")
          %p.text-xs.text-muted
            = t(".export_description")
        = render ::UI::ActionComponent.new(href: data_exports_path,
          method: :post,
          variant: :primary,
          size: :sm,
          class: "ml-4 shrink-0",
          form: { data: { turbo: false, controller: "iframe-download", action: "submit->iframe-download#submit" } }) do
          = t(".export_button")
      .border-t.pt-4.border-base-300
        = form_with url: data_imports_path, multipart: true do |f|
          .flex.items-center.justify-between.mb-3
            .min-w-0
              %p.text-sm.font-medium
                = t(".import_title")
              %p.text-xs.text-muted
                = t(".import_description")
          .flex.items-center.gap-3.min-w-0
            %label{ class: "flex items-center rounded-lg border overflow-hidden cursor-pointer flex-1 min-w-0 border-base-content/20", data: { controller: "file-picker", file_picker_no_file_text_value: t("common.no_file") } }
              %span{ class: "flex items-center self-stretch shrink-0 px-4 text-sm border-r border-base-content/20" }
                = t("common.choose_file")
              %span.text-sm.text-muted.flex-1.px-3.py-2.truncate{ data: { file_picker_target: "filename" } }
                = t("common.no_file")
              = f.file_field :file, accept: ".zip", class: "hidden", data: { file_picker_target: "input", action: "change->file-picker#update" }
            = render ::UI::ActionComponent.new(variant: :info,
              size: :sm,
              type: :submit,
              class: "shrink-0") do
              = t(".import_button")
