= turbo_frame_tag "monitoring", class: "block" do
  = render ::UI::CardComponent.new do |card|
    = card.with_header do
      %h2.text-sm.font-semibold.mb-1
        = t(".title")
      %p.text-sm.text-muted
        = t(".description")

    = card.with_body do
      .space-y-2
        = render ::UI::ActionComponent.new(href: "/pghero",
          variant: :default,
          class: "flex items-center justify-between rounded-lg border px-4 py-3 hover:border-primary transition-colors group border-base-300",
          target: "_blank") do |a|
          .min-w-0
            %p.text-sm.font-medium
              = t(".pghero_title")
            %p.text-xs.text-muted
              = t(".pghero_description")
          - a.with_trailing_icon(name: "fa-arrow-up-right-from-square", class: "text-muted group-hover:text-primary transition-colors shrink-0 ml-3")
        = render ::UI::ActionComponent.new(href: "/sidekiq",
          variant: :default,
          class: "flex items-center justify-between rounded-lg border px-4 py-3 hover:border-primary transition-colors group border-base-300",
          target: "_blank") do |a|
          .min-w-0
            %p.text-sm.font-medium
              = t(".sidekiq_title")
            %p.text-xs.text-muted
              = t(".sidekiq_description")
          - a.with_trailing_icon(name: "fa-arrow-up-right-from-square", class: "text-muted group-hover:text-primary transition-colors shrink-0 ml-3")

        - if user.kuma_url_in_database.present?
          = render ::UI::ActionComponent.new(href: user.kuma_url,
            variant: :default,
            class: "flex items-center justify-between rounded-lg border px-4 py-3 hover:border-primary transition-colors group border-base-300",
            target: "_blank") do |a|
            .min-w-0
              %p.text-sm.font-medium
                = t(".kuma_title")
              %p.text-xs.text-muted
                = t(".kuma_description")
            - a.with_trailing_icon(name: "fa-arrow-up-right-from-square", class: "text-muted group-hover:text-primary transition-colors shrink-0 ml-3")
        - else
          .flex.items-center.justify-between.rounded-lg.border.px-4.py-3.border-base-300
            .min-w-0
              %p.text-sm.font-medium
                = t(".kuma_setup_title")
              %p.text-xs.text-muted
                = t(".kuma_setup_hint")
                %span.font-mono.break-all
                  = t(".kuma_endpoint", host: request.host)

      -# Kuma URL setting
      .mt-4.border-t.border-base-300.pt-4
        = form_with model: user, url: settings_path, method: :patch, html: { class: "flex flex-col gap-2" } do |f|
          .flex.items-center.gap-3
            .flex-1.min-w-0
              = f.text_field :kuma_url,
                placeholder: "https://kuma.example.com",
                class: "input input-bordered input-sm w-full font-mono"
            = render ::UI::ActionComponent.new(variant: :primary,
              size: :sm,
              type: :submit,
              class: "shrink-0") do
              = "Save"
          - if user.errors[:kuma_url].any?
            %p.text-xs.text-error
              = user.errors[:kuma_url].first
