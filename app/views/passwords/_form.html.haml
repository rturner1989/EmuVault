= turbo_frame_tag :password_form do
  = simple_form_for @form || PasswordChangeForm.new, url: password_path, method: :patch, html: { id: "password-form", class: "space-y-4", autocomplete: "off", data: { turbo_frame: "_top" } } do |f|
    = f.input :current_password, as: :password, label: "Current password",
        input_html: { autocomplete: "current-password", class: "input input-bordered w-full" },
        label_html: { class: "label-text text-xs font-medium" }
    = f.input :password, as: :password, label: "New password",
        input_html: { autocomplete: "new-password", class: "input input-bordered w-full" },
        label_html: { class: "label-text text-xs font-medium" }
    = f.input :password_confirmation, as: :password, label: "Confirm new password",
        input_html: { autocomplete: "new-password", class: "input input-bordered w-full" },
        label_html: { class: "label-text text-xs font-medium" }
