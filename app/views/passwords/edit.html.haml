- content_for :title, "Change Password — EmuVault"

.p-4.lg:p-6
  = render ::UI::PageHeaderComponent.new(title: "Change Password")

  .rounded-lg.p-5{ class: "bg-base-100 border border-base-300" }
    = simple_form_for :password, url: password_path, method: :patch do |f|
      = f.input :current_password, as: :password, label: "Current password",
          input_html: { autocomplete: "current-password", class: "input input-bordered w-full" },
          label_html: { class: "label-text font-medium" },
          wrapper_html: { class: "mb-4" }
      = f.input :password, as: :password, label: "New password",
          input_html: { autocomplete: "new-password", class: "input input-bordered w-full" },
          label_html: { class: "label-text font-medium" },
          wrapper_html: { class: "mb-4" }
      = f.input :password_confirmation, as: :password, label: "Confirm new password",
          input_html: { autocomplete: "new-password", class: "input input-bordered w-full" },
          label_html: { class: "label-text font-medium" },
          wrapper_html: { class: "mb-6" }
      = f.button :submit, "Update password", class: "btn btn-primary"
