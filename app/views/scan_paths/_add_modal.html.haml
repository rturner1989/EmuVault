= render ::UI::ModalComponent.new(id: "add-scan-path-dialog", title: "Add Scan Path") do |modal|
  = modal.with_trigger do
    = render ::UI::ActionComponent.new(content_text: "Add path", variant: :secondary, data: { action: "dialog#open" }) do |a|
      - a.with_leading_icon(name: "fa-plus")
  = modal.with_body do
    = form_with model: ScanPath.new, url: scan_paths_path, method: :post, html: { class: "space-y-4", data: { controller: "directory-browser" } } do |f|

      -# Path input + browse button
      = f.label :path, "Directory path", class: "block text-sm mb-1"
      .flex.items-center.gap-2
        = f.text_field :path, placeholder: "/saves/gba/", required: true, class: "input input-bordered input-sm flex-1 min-w-0 font-mono", data: { "directory-browser-target": "input" }
        = render ::UI::ActionComponent.new(content_text: "Browse", variant: :ghost, class: "shrink-0", type: "button", data: { action: "click->directory-browser#toggle" }) do |a|
          - a.with_leading_icon(name: "fa-folder-open")

      -# File browser panel (hidden until Browse clicked)
      %div{ hidden: "", data: { "directory-browser-target": "browser" }, class: "rounded-lg border border-base-300 overflow-hidden" }
        -# Toolbar: up + current path + select
        .flex.items-center.gap-2.px-3.py-2{ class: "bg-base-200 border-b border-base-300" }
          %button.text-muted.hover:text-base-content.transition-colors.cursor-pointer.disabled:opacity-40{ type: "button", data: { action: "click->directory-browser#navigate", "directory-browser-target": "upButton", path: "/" } }
            %i.fa-solid.fa-arrow-up.fa-fw
          %span.text-xs.font-mono.text-muted.truncate.flex-1.min-w-0{ data: { "directory-browser-target": "currentPath" } } /
          = render ::UI::ActionComponent.new(content_text: "Select folder", variant: :primary, size: :xs, class: "shrink-0", type: "button", data: { action: "click->directory-browser#select" })

        -# Quick-jump shortcuts (populated dynamically from server mount points)
        .flex.items-center.flex-wrap.gap-1.px-3.py-2{ class: "border-b border-base-300" }
          %span.text-xs.text-muted.shrink-0 Jump to:
          .flex.items-center.flex-wrap.gap-1{ data: { "directory-browser-target": "shortcuts" } }

        -# Directory listing
        .max-h-48.overflow-y-auto{ data: { "directory-browser-target": "list" } }
          %p.text-xs.text-muted.px-3.py-3 Click Browse to explore

      %p.text-xs.text-muted
        Enter the path to your games directory.
        On a NAS or Docker setup, mount the directory as a volume first (e.g.
        %span.font-mono /saves
        ). On a local install, use the full path directly (e.g.
        %span.font-mono /home/user/games/gba
        ).

      -# Game system
      = f.label :game_system, "Game system", class: "block text-sm mb-1"
      = f.select :game_system, ScanPath.game_system.values.map { |v| [v.text, v.value] }, { include_blank: "Select system" }, class: "select select-bordered w-full", required: true

      -# Auto-scan toggle
      .flex.items-center.gap-2
        = f.check_box :auto_scan, class: "checkbox checkbox-primary"
        = f.label :auto_scan, "Include in auto-scan", class: "text-sm cursor-pointer"

      .pt-2
        = f.submit "Add path", class: "btn btn-primary w-full"
