= form_with model: ScanPath.new,
  url: scan_paths_path,
  method: :post,
  html: { class: "space-y-4", autocomplete: "off", data: { controller: "directory-browser" } } do |f|

  -# Path input + browse button
  = f.label :path, "Directory path", class: "block text-sm mb-1"
  .flex.items-center.gap-2
    .relative.flex-1.min-w-0
      = f.text_field :path, placeholder: "/saves/gba/",
        required: true,
        class: "input input-bordered input-sm w-full font-mono pr-8",
        data: { "directory-browser-target": "input" }
      = render ::UI::ActionComponent.new(variant: :default,
        type: :button,
        class: "absolute right-2 top-1/2 -translate-y-1/2 text-muted cursor-pointer hover:text-base-content transition-colors",
        data: { action: "click->directory-browser#clearInput" }) do |a|
        - a.with_leading_icon(name: "fa-xmark")
    = render ::UI::ActionComponent.new(variant: :ghost,
      class: "shrink-0",
      type: :button,
      data: { action: "click->directory-browser#toggle" }) do |a|
      - a.with_leading_icon(name: "fa-folder-open")
      = "Browse"

  = render "scan_paths/directory_browser"

  %p.text-xs.text-muted
    = "Enter the path to your games directory. "
    = "On a NAS or Docker setup, mount the directory as a volume first (e.g. "
    %span.font-mono
      = "/saves"
    = "). On a local install, use the full path directly (e.g. "
    %span.font-mono
      = "/home/user/games/gba"
    = ")."

  -# Game system
  = f.label :game_system, "Game system", class: "block text-sm mb-1"
  = f.select :game_system,
    ScanPath.game_system.values.map { |v| [v.text, v.value] },
    { include_blank: "Select system" },
    class: "select select-bordered w-full",
    required: true

  -# Auto-scan toggle
  .flex.items-center.gap-2
    = f.check_box :auto_scan, class: "checkbox checkbox-primary"
    = f.label :auto_scan, "Include in auto-scan", class: "text-sm cursor-pointer"

  .pt-2
    = render ::UI::ActionComponent.new(variant: :primary,
      type: :submit,
      class: "w-full") do
      = "Add path"
