- if import.analyzing?
  .flex.flex-col.items-center.justify-center.py-12
    %span.loading.loading-spinner.loading-lg.text-primary
    %p.text-sm.text-muted.mt-4
      = t(".analyzing")

- elsif import.failed?
  = render ::UI::EmptyStateComponent.new(title: t(".invalid_title"),
    description: t(".invalid_description")) do |c|
    - c.with_action do
      = render ::UI::ActionComponent.new(href: settings_path, variant: :primary) do
        = t(".back_to_settings")

- else
  - new_games = import.new_games
  - profiles = import.emulator_profiles

  -# Summary banner
  .rounded-lg.px-5.py-4.bg-base-100.border.border-base-300
    .flex.flex-wrap.gap-x-6.gap-y-1
      .flex.items-center.gap-2
        = render ::UI::IconComponent.new(name: "fa-gamepad", class: "text-primary")
        %span.text-sm
          = t(".game_count", count: import.manifest["games"].size)
      .flex.items-center.gap-2
        = render ::UI::IconComponent.new(name: "fa-floppy-disk", class: "text-primary")
        %span.text-sm
          = t(".save_count", count: import.total_saves)
      .flex.items-center.gap-2
        = render ::UI::IconComponent.new(name: "fa-microchip", class: "text-primary")
        %span.text-sm
          = t(".profile_count", count: profiles.size)
      - if import.conflicts.any?
        .flex.items-center.gap-2
          = render ::UI::IconComponent.new(name: "fa-triangle-exclamation", class: "text-accent")
          %span.text-sm.text-accent
            = t(".conflict_count", count: import.conflicts.size)

  = form_with url: data_import_resolution_path(import), class: "space-y-3" do |f|
    -# New games
    - if new_games.any?
      .rounded-lg.overflow-hidden.bg-base-100.border.border-base-300
        .flex.items-center.gap-2.px-4.py-3.border-b.border-base-300
          = render ::UI::IconComponent.new(name: "fa-circle-plus", class: "text-success")
          %h2.text-sm.font-semibold
            = t(".new_games", count: new_games.size)
          %span.text-xs.text-muted
            = t(".new_games_hint")
        .divide-y.divide-base-300
          - new_games.each do |game|
            .flex.items-center.justify-between.px-4.py-2.5
              %p.text-sm
                = game["title"]
              .flex.items-center.gap-3
                %span.text-xs.text-muted
                  = game["system"].upcase
                %span.text-xs.text-muted
                  = t(".save_count", count: game["saves"].size)

    -# Conflicts
    - if import.conflicts.any?
      .rounded-lg.overflow-hidden.bg-base-100.border.border-base-300
        .flex.items-center.gap-2.px-4.py-3.border-b.border-base-300
          = render ::UI::IconComponent.new(name: "fa-triangle-exclamation", class: "text-accent")
          %h2.text-sm.font-semibold
            = t(".existing_title", count: import.conflicts.size)
          %span.text-xs.text-muted
            = t(".existing_hint")
        .divide-y.divide-base-300
          - import.conflicts.each do |game|
            .px-4.py-3
              .flex.items-center.justify-between.mb-2.5
                .min-w-0
                  %p.text-sm.font-medium
                    = game["title"]
                  %p.text-xs.text-muted.mt-0.5
                    = "#{game["system"].upcase} · #{t(".save_count", count: game["saves"].size)}"
                = render ::UI::BadgeComponent.new(color: :orange, class: "ml-3 shrink-0") do
                  = t(".exists")
              .flex.gap-6
                %label.flex.items-center.gap-2.cursor-pointer
                  %input{ type: "radio", name: "resolutions[#{game["export_id"]}]", value: "skip", checked: true, class: "accent-primary" }
                  .min-w-0
                    %p.text-sm
                      = t(".keep_existing")
                    %p.text-xs.text-muted
                      = t(".keep_hint")
                %label.flex.items-center.gap-2.cursor-pointer
                  %input{ type: "radio", name: "resolutions[#{game["export_id"]}]", value: "replace", class: "accent-primary" }
                  .min-w-0
                    %p.text-sm
                      = t(".replace")
                    %p.text-xs.text-muted
                      = t(".replace_hint")

    -# Emulator profiles
    - if profiles.any?
      .rounded-lg.overflow-hidden.bg-base-100.border.border-base-300
        .flex.items-center.gap-2.px-4.py-3.border-b.border-base-300
          = render ::UI::IconComponent.new(name: "fa-microchip", class: "text-info")
          %h2.text-sm.font-semibold
            = t(".profiles_title", count: profiles.size)
          %span.text-xs.text-muted
            = t(".profiles_hint")
        .divide-y.divide-base-300
          - profiles.each do |profile|
            .flex.items-center.justify-between.px-4.py-2.5
              %p.text-sm
                = profile["name"]
              %span.text-xs.text-muted
                = profile["platform"].to_s.capitalize

    -# Actions
    .flex.items-center.justify-between.pt-1
      = render ::UI::ActionComponent.new(href: settings_path, variant: :ghost) do
        = t(".cancel")
      = render ::UI::ActionComponent.new(variant: :primary, type: :submit) do
        = t(".start_import")
