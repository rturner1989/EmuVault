- content_for :title, "Setup — EmuVault"

= render layout: "setup/wizard_shell", locals: { current_step: 3 } do
  .rounded-lg.overflow-hidden{ class: "bg-base-100 border border-base-300" }

    .px-5.py-4{ class: "border-b border-base-300" }
      %h2.text-base.font-semibold Where do your emulators store saves?
      %p.text-sm.text-muted.mt-0.5 Used to show you where to put downloaded files. Leave blank for mobile-only emulators.

    = form_with url: save_configuration_setup_path, method: :patch do |f|
      .divide-y{ class: "divide-base-300" }
        - @profiles_by_emulator.each do |(emulator_name, platform), profiles|
          - key = "#{emulator_name}|#{platform}"
          - systems_text = profiles.map { |p| p.game_system.text }.join(", ")
          .px-5.py-4
            .flex.items-center.gap-2.mb-1
              %span.text-sm.font-medium= emulator_name
              = render ::UI::BadgeComponent.new(context_text: profiles.first.platform.text, color: platform_badge_color(platform))
            %p.text-xs.text-muted.mb-2= systems_text
            %input.input.input-bordered.w-full.font-mono{ type: "text", name: "emulators[#{key}][default_save_path]", value: profiles.first.default_save_path, placeholder: "e.g. ~/.config/retroarch/saves/" }

      .px-5.py-4.flex.gap-3{ class: "border-t border-base-300" }
        = link_to profiles_setup_path, class: "btn btn-ghost flex-1" do
          %i.fa-solid.fa-arrow-left
          Back
        %button.btn.btn-primary.flex-1{ type: "submit" }
          Next
          %i.fa-solid.fa-arrow-right
