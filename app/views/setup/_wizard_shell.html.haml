-# Renders the wizard chrome: logo, step indicator, and a centred card.
-# Usage: = render "wizard_shell", current_step: 1 do
-#   ...content...
.min-h-screen.flex.items-start.justify-center.p-6.pt-10{ class: "bg-base-200" }
  .w-full{ style: "max-width: 560px" }
    .text-center.mb-8
      %h1.text-2xl.font-bold.text-primary.mb-4 EmuVault

      -# Step indicator
      .flex.items-center.justify-center.gap-2
        - [["1", "Account", setup_path], ["2", "Emulators", profiles_setup_path], ["3", "Paths", configure_setup_path], ["4", "Library", library_setup_path]].each_with_index do |(num, label, _path), i|
          - active = current_step == i + 1
          - done = current_step > i + 1
          .flex.items-center.gap-2
            %span.w-7.h-7.rounded-full.flex.items-center.justify-center.text-xs.font-bold{ class: active ? "bg-primary text-primary-content" : done ? "bg-success text-primary-content" : "bg-base-300 text-muted" }
              - if done
                %i.fa-solid.fa-check
              - else
                = num
            %span.text-xs{ class: active ? "text-base-content" : "text-muted" }= label
          - if i < 3
            .h-px.w-6{ class: "bg-base-300" }

    = yield
