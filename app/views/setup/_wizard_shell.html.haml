-# Renders the wizard chrome: logo, step indicator, and a centred card.
.flex-1.flex.justify-center.overflow-hidden.bg-base-200{ style: "padding: max(env(safe-area-inset-top), 2.5rem) 1.5rem max(env(safe-area-inset-bottom), 1.5rem)" }
  .w-full.flex.flex-col.min-h-0{ style: "max-width: 560px" }
    .text-center.mb-8.shrink-0
      .flex.justify-center.mb-4
        = render ::UI::LogoComponent.new(size: :lg)

      -# Step indicator
      .flex.items-center.justify-center.gap-2
        - [["1", "Emulators"], ["2", "Paths"], ["3", "Library"]].each_with_index do |(num, label), i|
          - active = current_step == i + 1
          - done = current_step > i + 1
          .flex.items-center.gap-2
            - if active
              - step_class = "bg-primary text-primary-content"
            - elsif done
              - step_class = "bg-success text-success-content"
            - else
              - step_class = "bg-base-300 text-muted"
            %span{ class: "w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold #{step_class}" }
              = num
            %span.text-xs{ class: active ? "text-base-content" : "text-muted" }
              = label
          - if i < 2
            .h-px.w-6.bg-base-300

    .flex-1.flex.flex-col.min-h-0
      = yield
