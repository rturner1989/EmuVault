- content_for :title, "Setup — EmuVault"

= render layout: "setup/wizard_shell", locals: { current_step: 1 } do
  - if params[:system].present?
    -# Step 1b — emulator picker for a specific system
    - system_key = params[:system]
    - system_label = EmulatorProfile.game_system.find_value(system_key)&.text || system_key.upcase
    - profiles = EmulatorProfile.where(is_default: true, game_system: system_key).ordered
    - pending = Array(session[:pending_systems])
    - current_pos = pending.index(system_key)

    = form_with url: select_profiles_setup_path, method: :post, class: "flex-1 flex flex-col min-h-0" do |f|
      = hidden_field_tag :redirect_system, system_key
      = render ::UI::CardComponent.new(scrollable: true, class: "flex-1") do |c|
        - c.with_header do
          .flex.items-center.gap-3.mb-1
            = render ::UI::ActionComponent.new(href: profiles_setup_path,
              variant: :default,
              class: "text-muted hover:text-base-content transition-colors") do |a|
              - a.with_leading_icon(name: "fa-arrow-left")
            %h2.text-base.font-semibold
              = system_label
            - if pending.size > 1 && current_pos
              %span.text-xs.text-muted
                = "(#{current_pos + 1}/#{pending.size})"
          %p.text-sm.text-muted.mt-0.5
            = "Select the emulators you have installed for this system."

        - c.with_footer do
          .flex.gap-3
            = render ::UI::ActionComponent.new(href: profiles_setup_path,
              variant: :ghost,
              class: "flex-1") do |a|
              - a.with_leading_icon(name: "fa-arrow-left")
              = "Back"
            = render ::UI::ActionComponent.new(variant: :primary,
              type: :submit,
              class: "flex-1") do |a|
              = "Continue"
              - a.with_trailing_icon(name: "fa-arrow-right")

        .divide-y.divide-base-300
          - profiles.each do |profile|
            %label{ class: "flex items-center gap-3 px-5 py-3 cursor-pointer hover:bg-base-200" }
              %input.accent-primary{ type: "checkbox", name: "profile_ids[]", value: profile.id, checked: profile.user_selected }
              .flex-1.min-w-0
                %p.text-sm.font-medium
                  = profile.name
                = render ::UI::BadgeComponent.new(color: platform_badge_color(profile.platform)) do
                  = profile.platform.text
              %span.text-xs.text-muted.font-mono.shrink-0
                = ".#{profile.save_extension}"

  - else
    -# Step 1a — system picker (multi-select)
    - selected_systems = EmulatorProfile.where(user_selected: true).distinct.pluck(:game_system).compact
    - all_systems = EmulatorProfile.game_system.values

    = form_with url: select_systems_setup_path, method: :post, class: "flex-1 flex flex-col min-h-0" do |f|
      = render ::UI::CardComponent.new(scrollable: true, class: "flex-1") do |c|
        - c.with_header do
          %h2.text-base.font-semibold
            = "Which systems do you use?"
          %p.text-sm.text-muted.mt-0.5
            = "Select all the systems you want to set up."

        - c.with_footer do
          = render ::UI::ActionComponent.new(variant: :primary,
            type: :submit,
            class: "w-full") do |a|
            = "Next"
            - a.with_trailing_icon(name: "fa-arrow-right")

        .p-4
          .grid.gap-2{ style: "grid-template-columns: repeat(auto-fill, minmax(130px, 1fr))" }
            - all_systems.each do |system|
              - checked = selected_systems.include?(system.value)
              %label{ class: "flex flex-col items-center gap-1.5 px-3 py-4 rounded-lg border text-center cursor-pointer transition-all border-base-300 hover:border-primary hover:bg-base-200 has-[:checked]:border-primary has-[:checked]:bg-base-200" }
                %input{ type: "checkbox", name: "system_keys[]", value: system.value, checked: checked, class: "peer sr-only" }
                %span.text-sm.font-medium
                  = system.text
                = render ::UI::IconComponent.new(name: "fa-check", class: "text-xs text-primary invisible peer-checked:visible")
