- if @quick_sync_game
  .space-y-4
    -# Game header
    .flex.items-center.justify-between.gap-3
      .min-w-0
        %p.text-base.font-semibold.text-drac-fg.truncate= @quick_sync_game.title
        = render ::UI::BadgeComponent.new(label: @quick_sync_game.system.text, color: :comment)
      .flex.items-center.gap-2.shrink-0
        = link_to game_path(@quick_sync_game), class: "text-xs text-drac-purple hover:underline cursor-pointer" do
          View →
        = button_to current_game_path, method: :delete, class: "text-xs text-drac-comment hover:text-drac-red transition-colors cursor-pointer px-2 py-1 rounded border border-drac-current hover:border-drac-red" do
          Clear

    - if @quick_sync_save
      .text-xs.text-drac-comment
        Last save:
        %span.text-drac-fg= @quick_sync_save.uploaded_at_label

    -# Download
    - if @quick_sync_save
      .rounded-lg.bg-drac-surface.border.border-drac-current.p-4
        %p.text-xs.font-medium.text-drac-fg.mb-3 Download to device
        = simple_form_for :game_save, url: download_game_game_save_path(@quick_sync_game, @quick_sync_save), method: :get, html: { data: { controller: "save-hint", turbo: false } } do |f|
          .space-y-3
            = f.select :target_profile_id,
                @quick_sync_profiles.map { |p| ["#{p.name} (#{p.platform.text})", p.id, { data: { path: @quick_sync_save.save_path_hint(p) } }] },
                { include_blank: "Select emulator…" },
                { class: "block w-full rounded-lg bg-drac-bg border border-drac-current text-drac-fg text-sm px-3 py-2 cursor-pointer focus:outline-none focus:border-drac-cyan", data: { action: "change->save-hint#update", save_hint_target: "select" } }
            .hidden{ data: { save_hint_target: "note" } }
              %p.text-xs.text-drac-comment.mb-1 Place file at:
              .flex.items-center.gap-2.mb-2
                %p.text-xs.text-drac-fg.font-mono.flex-1{ data: { save_hint_target: "hint" } }
                %button.text-drac-comment.hover:text-drac-fg.transition-colors.cursor-pointer{ type: "button", title: "Copy path", data: { action: "save-hint#copy", save_hint_target: "copyBtn" } }
                  %i.fa-regular.fa-clipboard.fa-fw
            %button{ type: "submit", class: "w-full rounded-lg bg-drac-cyan px-4 py-2 text-sm font-semibold text-drac-bg cursor-pointer hover:opacity-80 active:opacity-70 transition-opacity inline-flex items-center justify-center gap-2" }
              %i.fa-solid.fa-download
              Download
    - else
      .rounded-lg.bg-drac-surface.border.border-drac-current.p-4.text-center
        %p.text-xs.text-drac-comment No save uploaded yet. Upload one below.

    -# Upload
    .rounded-lg.bg-drac-surface.border.border-drac-current.p-4
      %p.text-xs.font-medium.text-drac-fg.mb-3 Upload new save
      = simple_form_for :game_save, url: game_game_saves_path(@quick_sync_game), method: :post, html: { multipart: true, class: "space-y-3", data: { turbo: false } } do |f|
        = f.select :emulator_profile_id,
            @quick_sync_profiles.map { |p| ["#{p.name} (#{p.platform.text})", p.id] },
            { include_blank: "Source emulator (optional)" },
            { class: "block w-full rounded-lg bg-drac-bg border border-drac-current text-drac-fg text-sm px-3 py-2 cursor-pointer focus:outline-none focus:border-drac-purple" }
        = f.file_field :file, required: true, class: "block w-full text-sm text-drac-comment cursor-pointer file:mr-3 file:rounded-lg file:border-0 file:bg-drac-current file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-drac-fg file:cursor-pointer hover:file:bg-drac-fg hover:file:text-drac-bg file:transition-colors"
        %button{ type: "submit", class: "w-full rounded-lg bg-drac-purple px-4 py-2 text-sm font-semibold text-drac-bg cursor-pointer hover:opacity-80 active:opacity-70 transition-opacity inline-flex items-center justify-center gap-2" }
          %i.fa-solid.fa-upload
          Upload

- else
  .text-center.py-6.space-y-2
    %i.fa-solid.fa-rotate.text-2xl.text-drac-comment
    %p.text-sm.text-drac-comment No game set as Now Playing.
    %p.text-xs.text-drac-comment Open a game and tap "Set as current" to enable quick sync.
