- content_for :title, "#{@game.title} — EmuVault"

.p-4.lg:p-6.space-y-4
  -# Back breadcrumb
  .mb-4
    = render ::UI::ActionComponent.new(href: games_path,
      variant: :link,
      class: "text-xs text-muted hover:text-base-content transition-colors") do |a|
      - a.with_leading_icon(name: "fa-arrow-left")
      = "Games"

  = render "games/header", game: @game

  -# Save panel
  = turbo_frame_tag :save_panel do
    - if @latest_save
      .rounded-lg.overflow-hidden.mb-5.bg-base-100.border.border-base-300
        -# Current save header
        .px-4.py-3.border-b.border-base-300
          .flex.items-center.justify-between
            %h2.text-sm.font-semibold
              = "Current Save"
              %span.text-xs.font-normal.text-muted.ml-2
                = "v#{@latest_save.version_number}"
            .text-xs.text-muted{ title: @latest_save.uploaded_at_label }
              = time_ago_in_words(@latest_save.created_at) + " ago"

          .flex.items-center.gap-2.mt-1.text-xs.text-muted
            - if @latest_save.emulator_profile
              = render ::UI::BadgeComponent.new(color: platform_badge_color(@latest_save.emulator_profile.platform)) do
                = @latest_save.emulator_profile.platform_label
              %span
                = @latest_save.emulator_label
            - else
              %span
                = "Unknown source"
            %span
              = "· #{@latest_save.file_size_label}"

        -# Download
        .px-4.py-4
          = simple_form_for :game_save,
            url: game_game_save_download_path(@game, @latest_save),
            method: :get,
            html: { data: { controller: "save-hint iframe-download", action: "submit->iframe-download#submit", turbo: false } } do |f|
            .space-y-2
              = f.select :target_profile_id,
                @user_profiles.map { |p| ["#{p.name} (#{p.platform_label}) (.#{p.save_extension})", p.id, { data: { path: @latest_save.save_path_hint(p) } }] },
                { include_blank: "Select emulator to download for…" },
                { class: "select select-bordered w-full", data: { action: "change->save-hint#update", save_hint_target: "select" } }
              .hidden{ data: { save_hint_target: "note" } }
                %p.text-xs.text-muted.mb-2
                  = "Place the downloaded file at:"
                .flex.items-center.gap-2.mb-2
                  %p.text-xs.font-mono.flex-1{ data: { save_hint_target: "hint" } }
                  = render ::UI::ActionComponent.new(variant: :default,
                    type: :button,
                    class: "text-muted hover:text-base-content transition-colors cursor-pointer",
                    title: "Copy Path",
                    data: { action: "save-hint#copy", save_hint_target: "copyBtn" }) do |a|
                    - a.with_leading_icon(name: "fa-clipboard", style: "fa-regular")
                %p.text-xs.text-muted
                  = "Your browser will save it to Downloads — move it to the path above."
              .flex.justify-start
                = render ::UI::ActionComponent.new(variant: :info, type: "submit") do |a|
                  - a.with_leading_icon(name: "fa-download")
                  = "Download"

        -# Upload new version
        .px-4.py-3.border-t.border-base-300
          %h2.text-sm.font-semibold
            = "Upload New Version"
        .px-4.pb-4
          = render "games/upload_form", game: @game, user_profiles: @user_profiles, new_save: @new_save, submit_label: "Upload"

    - else
      -# No save yet
      .rounded-lg.overflow-hidden.bg-base-100.border.border-base-300
        .px-4.py-3.border-b.border-base-300
          %h2.text-sm.font-semibold
            = "Upload Save File"
        .p-4
          = render "games/upload_form", game: @game, user_profiles: @user_profiles, new_save: @new_save, submit_label: "Upload Save"

    -# History
    - if @history.any?
      - history_all = @history
      - history_preview = history_all.first(5)
      .rounded-lg.overflow-hidden.bg-base-100.border.border-base-300{ data: { controller: "iframe-download" } }
        - if history_all.size > 5
          = render ::UI::ModalComponent.new(id: "save-history-dialog",
            title: "Save History") do |modal|
            = modal.with_trigger do
              .px-4.py-3.flex.items-center.justify-between.border-b.border-base-300
                %h2.text-sm.font-semibold
                  = "Previous Versions"
                = render ::UI::ActionComponent.new(variant: :ghost,
                  data: { action: "dialog#open" }) do
                  = "View all #{history_all.size}"
            = modal.with_body do
              .divide-y.divide-base-300
                - history_all.each do |save|
                  = render "games/save_row", save: save, game: @game
        - else
          .px-4.py-3.border-b.border-base-300
            %h2.text-sm.font-semibold
              = "Previous Versions"

        .divide-y.divide-base-300
          - history_preview.each do |save|
            = render "games/save_row", save: save, game: @game

  -# Emulator save filenames
  = render "games/emulator_filenames", game: @game, user_profiles: @user_profiles, emulator_configs: @emulator_configs
