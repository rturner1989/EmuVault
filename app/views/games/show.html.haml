- content_for :title, "#{@game.title} — EmuVault"

.p-4.lg:p-6.space-y-4
  -# Header
  .flex.items-center.gap-3
    = link_to games_path, class: "text-drac-comment hover:text-drac-fg shrink-0" do
      ← Back
    .flex-1.min-w-0
      %h1.text-xl.font-bold.text-drac-fg.truncate= @game.title
      = render ::UI::BadgeComponent.new(label: @game.system.text, color: :comment)
    .flex.gap-2.shrink-0
      = link_to "Edit", edit_game_path(@game), class: "rounded border border-drac-current px-3 py-1.5 text-xs text-drac-comment"
      = button_to "✕", game_path(@game), method: :delete, data: { turbo_confirm: "Remove #{@game.title}?" }, class: "rounded border border-drac-red px-3 py-1.5 text-xs text-drac-red bg-transparent cursor-pointer"

  -# Latest save
  - if @latest_save
    .rounded-lg.bg-drac-bg.border.border-drac-current.overflow-hidden
      .px-4.py-3.border-b.border-drac-current.flex.items-center.justify-between
        %h2.text-sm.font-semibold.text-drac-fg Current Save
        .text-xs.text-drac-comment= @latest_save.uploaded_at_label

      .p-4.space-y-3
        .flex.items-center.gap-2.text-xs.text-drac-comment
          - if @latest_save.emulator_profile
            = render ::UI::BadgeComponent.new(label: @latest_save.emulator_profile.platform.text, color: platform_badge_color(@latest_save.emulator_profile.platform))
            %span= @latest_save.emulator_label
          - else
            %span Unknown source
          %span · #{@latest_save.file_size_label}

        -# Download with profile selector
        = form_with url: download_game_game_save_path(@game, @latest_save), method: :get, data: { controller: "save-hint" } do |f|
          .space-y-2
            = f.select :target_profile_id,
                @user_profiles.map { |p| ["#{p.name} (#{p.platform.text})", p.id, { data: { path: @latest_save.save_path_hint(p) } }] },
                { include_blank: "Select emulator to download for…" },
                { class: "block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2", data: { action: "change->save-hint#update", save_hint_target: "select" } }
            -# Save path hint
            %p.text-xs.text-drac-comment.font-mono.hidden{ data: { save_hint_target: "hint" } }
            = f.submit "⬇  Download", class: "w-full rounded-lg bg-drac-cyan py-3 text-sm font-semibold text-drac-bg cursor-pointer"

      -# Upload new version
      .px-4.pb-4
        %details.rounded-lg.border.border-drac-current.overflow-hidden
          %summary.px-4.py-3.text-sm.font-medium.text-drac-comment.cursor-pointer ⬆  Upload new version
          .p-4.border-t.border-drac-current
            = form_with url: game_game_saves_path(@game), method: :post, multipart: true, scope: :game_save, class: "space-y-3" do |f|
              = f.select :emulator_profile_id,
                  @user_profiles.map { |p| ["#{p.name} (#{p.platform.text})", p.id] },
                  { include_blank: "Which emulator is this save from? (optional)" },
                  { class: "block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2" }
              = f.file_field :file, class: "block w-full text-sm text-drac-comment file:mr-3 file:rounded-lg file:border-0 file:bg-drac-current file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-drac-fg"
              = f.submit "Upload", class: "w-full rounded-lg bg-drac-purple py-3 text-sm font-semibold text-drac-bg cursor-pointer"

  - else
    -# No save yet — full upload card
    .rounded-lg.bg-drac-bg.border.border-drac-current.overflow-hidden
      .px-4.py-3.border-b.border-drac-current
        %h2.text-sm.font-semibold.text-drac-fg Upload Save File
      .p-4
        = form_with url: game_game_saves_path(@game), method: :post, multipart: true, scope: :game_save, class: "space-y-3" do |f|
          = f.select :emulator_profile_id,
              @user_profiles.map { |p| ["#{p.name} (#{p.platform.text})", p.id] },
              { include_blank: "Which emulator is this save from? (optional)" },
              { class: "block w-full rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2" }
          = f.file_field :file, class: "block w-full text-sm text-drac-comment file:mr-3 file:rounded-lg file:border-0 file:bg-drac-current file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-drac-fg"
          = f.submit "Upload Save", class: "w-full rounded-lg bg-drac-purple py-3 text-sm font-semibold text-drac-bg cursor-pointer"

  -# History
  - if @history.exists?
    %details.rounded-lg.bg-drac-bg.border.border-drac-current.overflow-hidden
      %summary.px-4.py-3.text-sm.font-medium.text-drac-comment.cursor-pointer Previous versions (#{@history.count})
      .divide-y.divide-drac-current
        - @history.each do |save|
          - decorated = GameSaveDecorator.new(save)
          .flex.items-center.gap-3.px-4.py-3
            .flex-1.min-w-0
              .text-sm.text-drac-fg= decorated.uploaded_at_label
              .text-xs.text-drac-comment= "#{decorated.emulator_label} · #{decorated.file_size_label}"
            = link_to "↓", download_game_game_save_path(@game, save), class: "text-xs text-drac-cyan px-3 py-1.5 rounded border border-drac-cyan shrink-0"
