- decorated = GameSaveDecorator.new(save)
.flex.items-center.gap-3.px-4.py-3
  .flex-1.min-w-0
    .text-sm
      = decorated.uploaded_at_label
    .text-xs.text-muted
      = "#{decorated.emulator_label} · #{decorated.file_size_label}"
  = render ::UI::ActionComponent.new(href: download_game_game_save_path(game, save),
    variant: :info,
    size: :sm,
    class: "btn-outline",
    data: { turbo: false, action: "click->iframe-download#click" }) do |a|
    - a.with_leading_icon(name: "fa-download")
