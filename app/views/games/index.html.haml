- content_for :title, "Games — EmuVault"

.p-4
  = render ::UI::ModalComponent.new(id: "add-game-dialog", title: "Add Game") do |modal|
    = modal.with_trigger do
      = render ::UI::PageHeaderComponent.new(title: "Games") do |header|
        - header.with_action do
          = render ::UI::ActionComponent.new(content_text: "Add Game", variant: :primary, data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
    = modal.with_body do
      = render "games/form", form_url: games_path, submit_label: "Add Game", cancel_path: games_path
    = modal.with_page_content do
      - if @games.any? || @selected_system.present?
        .mb-4
          = form_with url: games_path, method: :get, data: { controller: "auto-submit" } do
            .flex.items-center.gap-2.flex-wrap
              - if @system_options.size > 1
                = select_tag :system, options_for_select([["All systems", ""], *@system_options], @selected_system), class: "select select-bordered select-sm w-44", data: { action: "change->auto-submit#submit" }
              = select_tag :sort, options_for_select([["Title A→Z", "title_asc"], ["Title Z→A", "title_desc"], ["Newest first", "newest"], ["Oldest first", "oldest"], ["By system", "system"]], @selected_sort), class: "select select-bordered select-sm w-44", data: { action: "change->auto-submit#submit" }
              - if @selected_system.present?
                = link_to games_path(sort: @selected_sort), class: "text-xs text-drac-comment hover:text-base-content transition-colors inline-flex items-center gap-1" do
                  %i.fa-solid.fa-xmark
                  Clear
      - if @games.empty?
        = render ::UI::EmptyStateComponent.new(title: "No games yet", description: "Add your first game to start syncing saves.") do |c|
          - c.with_action do
            = render ::UI::ActionComponent.new(content_text: "Add Game", variant: :primary, data: { action: "dialog#open" }) do |a|
              - a.with_leading_icon(name: "fa-plus")
      - else
        .space-y-3
          - @games.each do |game|
            - is_current = current_user.current_game_id == game.id
            .rounded-lg.border.transition-colors.flex.overflow-hidden{ class: is_current ? "bg-base-100 border-primary" : "bg-base-100 border-base-300" }
              = link_to game_path(game), class: "flex-1 min-w-0 p-4 flex items-center justify-between gap-3 hover:bg-base-200 transition-colors" do
                .min-w-0
                  .text-base.font-semibold.truncate= game.title
                  .mt-1
                    = render ::UI::BadgeComponent.new(context_text: game.system_label, color: game.system_badge_color)
                %i.fa-solid.fa-chevron-right.text-drac-comment.shrink-0
              .border-l.flex.items-center{ class: "border-base-300" }
                - if is_current
                  = button_to current_game_path, method: :delete, title: "Clear current game", class: "h-full px-4 flex items-center text-primary hover:opacity-70 transition-opacity cursor-pointer" do
                    %i.fa-solid.fa-rotate.fa-fw
                - else
                  = button_to current_game_path, method: :patch, params: { game_id: game.id }, title: "Set as current game", class: "h-full px-4 flex items-center text-drac-comment hover:text-primary transition-colors cursor-pointer" do
                    %i.fa-solid.fa-rotate.fa-fw
