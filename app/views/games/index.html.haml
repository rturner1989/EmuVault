- content_for :title, "Games — EmuVault"

= turbo_stream_from "scans_#{current_user.id}"

.p-4.lg:p-6
  = render ::UI::ModalComponent.new(id: "add-game-dialog", title: "Add Game") do |modal|
    = modal.with_trigger do
      = render ::UI::PageHeaderComponent.new(title: "Games") do |header|
        - header.with_action do
          .flex.items-center.gap-2
            = render ::UI::ActionComponent.new(href: game_scan_path,
              method: :post,
              variant: :ghost,
              size: :sm) do |a|
              - a.with_leading_icon(name: "fa-magnifying-glass")
              = "Scan Library"
            = render ::UI::ActionComponent.new(variant: :primary, data: { action: "dialog#open" }) do |a|
              - a.with_leading_icon(name: "fa-plus")
              = "Add Game"

    = modal.with_body do
      = render "games/form", form_url: games_path, form_id: "add-game-form"

    = modal.with_footer do
      = render ::UI::ActionComponent.new(variant: :primary,
        size: :sm,
        type: :submit,
        form: "add-game-form") do
        = "Add Game"

    = modal.with_page_content do
      = turbo_frame_tag "games-filters", style: "display: contents", target: "_top" do
        = render "games/filters",
          games_count: @games.size,
          system_options: @system_options,
          selected_system: @selected_system,
          selected_sort: @selected_sort

      = turbo_frame_tag "games-list", class: "space-y-3 block" do
        - if @games.empty?
          = render ::UI::EmptyStateComponent.new(title: "No games yet", description: "Add your first game to start syncing saves.") do |c|
            - c.with_action do
              = render ::UI::ActionComponent.new(variant: :primary, data: { action: "dialog#open" }) do |a|
                - a.with_leading_icon(name: "fa-plus")
                = "Add Game"
        - elsif @selected_sort == "system"
          .space-y-6
            - @games.group_by(&:system).each do |system_key, system_games|
              - system_label = Game.game_system_label(system_key)
              %div
                %p.text-sm.font-medium.mb-2
                  = system_label
                .space-y-3
                  = render "games/game_list", games: system_games
        - elsif @selected_system.present?
          - system_label = Game.game_system_label(@selected_system)
          %div
            %p.text-sm.font-medium.mb-2
              = system_label
            .space-y-3
              = render "games/game_list", games: @games
        - else
          = render "games/game_list", games: @games

  -# Scan review modal — opens on scan or when pending auto-scan results exist
  = render ::UI::ModalComponent.new(id: "scan-review-dialog", title: "Scan Review", subtitle: "Select the games you want to add to your library", auto_open: @pending_scan) do |modal|
    = modal.with_body do
      = turbo_frame_tag "scan-review-content" do
        - if @pending_scan
          = render "games/scans/review_content", found: @scan_found, already_in_lib: @scan_already_in_lib, skipped_paths: @scan_skipped_paths, grouped: @scan_grouped
        - else
          = render "games/scan_progress"
    = modal.with_footer do
      = render ::UI::ActionComponent.new(variant: :primary,
        size: :sm,
        type: :submit,
        form: "scan-confirm-form") do
        = "Add to library"

