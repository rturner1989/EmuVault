- content_for :title, "Games — EmuVault"

.p-4
  = render ::UI::ModalComponent.new(id: "add-game-dialog", title: "Add Game") do |modal|
    = modal.with_trigger do
      = render ::UI::PageHeaderComponent.new(title: "Games") do |header|
        - header.with_action do
          %button{ class: "rounded-lg bg-drac-purple px-4 py-2 text-sm font-medium text-drac-bg hover:opacity-90 active:opacity-70 transition-opacity cursor-pointer inline-flex items-center gap-2", data: { action: "dialog#open" } }
            %i.fa-solid.fa-plus
            Add Game
    = modal.with_body do
      = render "games/form", form_url: games_path, submit_label: "Add Game", cancel_path: games_path
    = modal.with_page_content do
      - if @games.any? || @selected_system.present?
        .mb-4
          = form_with url: games_path, method: :get, data: { controller: "auto-submit" } do
            .flex.items-center.gap-2.flex-wrap
              - if @system_options.size > 1
                = select_tag :system, options_for_select([["All systems", ""], *@system_options], @selected_system), class: "rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2 cursor-pointer focus:outline-none focus:border-drac-cyan", data: { action: "change->auto-submit#submit" }
              = select_tag :sort, options_for_select([["Title A→Z", "title_asc"], ["Title Z→A", "title_desc"], ["Newest first", "newest"], ["Oldest first", "oldest"], ["By system", "system"]], @selected_sort), class: "rounded-lg bg-drac-surface border border-drac-current text-drac-fg text-sm px-3 py-2 cursor-pointer focus:outline-none focus:border-drac-cyan", data: { action: "change->auto-submit#submit" }
              - if @selected_system.present?
                = link_to games_path(sort: @selected_sort), class: "text-xs text-drac-comment hover:text-drac-fg transition-colors inline-flex items-center gap-1" do
                  %i.fa-solid.fa-xmark
                  Clear
      - if @games.empty?
        = render ::UI::EmptyStateComponent.new(title: "No games yet", description: "Add your first game to start syncing saves.") do |c|
          - c.with_action do
            %button{ class: "rounded-lg bg-drac-purple px-4 py-2 text-sm font-medium text-drac-bg hover:opacity-90 transition-opacity cursor-pointer inline-flex items-center gap-2", data: { action: "dialog#open" } }
              %i.fa-solid.fa-plus
              Add Game
      - else
        .space-y-3
          - @games.each do |game|
            = link_to game_path(game), class: "block rounded-lg bg-drac-bg border border-drac-current p-4 hover:border-drac-purple transition-colors" do
              .flex.items-start.justify-between.gap-3
                .min-w-0
                  .text-base.font-semibold.text-drac-fg.truncate= game.title
                  .mt-1
                    = render ::UI::BadgeComponent.new(label: game.system_label, color: game.system_badge_color)
                %i.fa-solid.fa-chevron-right.text-drac-comment.mt-1
