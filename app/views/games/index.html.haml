- content_for :title, "Games — EmuVault"

.p-4
  = render ::UI::ModalComponent.new(id: "add-game-dialog", title: "Add Game") do |modal|
    = modal.with_trigger do
      = render ::UI::PageHeaderComponent.new(title: "Games") do |header|
        - header.with_action do
          = render ::UI::ActionComponent.new(content_text: "Add Game", variant: :primary, data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")

    = modal.with_body do
      = render "games/form", form_url: games_path, form_id: "add-game-form"

    = modal.with_footer do
      = render ::UI::ActionComponent.new(content_text: "Add Game", variant: :primary, size: :sm, type: :submit, form: "add-game-form")

    = modal.with_page_content do
      - if @games.size > 1 || @selected_system.present?
        .mb-4
          = form_with url: games_path, method: :get, data: { controller: "auto-submit" } do
            .flex.items-center.gap-2.flex-wrap
              - if @system_options.size > 1
                = select_tag :system,
                  options_for_select([["All systems", ""], *@system_options], @selected_system),
                  class: "select select-bordered select-sm w-44",
                  data: { action: "change->auto-submit#submit" }

              = select_tag :sort,
                options_for_select(game_sort_options, @selected_sort),
                class: "select select-bordered select-sm w-44",
                data: { action: "change->auto-submit#submit" }

              - if @selected_system.present?
                = link_to games_path(sort: @selected_sort),
                  class: "text-xs text-muted hover:text-base-content transition-colors inline-flex items-center gap-1" do
                  = render ::UI::IconComponent.new(name: "fa-xmark")
                  = "Clear"

      = turbo_frame_tag "games-list", class: "space-y-3" do
        - if @games.empty?
          = render ::UI::EmptyStateComponent.new(title: "No games yet", description: "Add your first game to start syncing saves.") do |c|
            - c.with_action do
              = render ::UI::ActionComponent.new(content_text: "Add Game", variant: :primary, data: { action: "dialog#open" }) do |a|
                - a.with_leading_icon(name: "fa-plus")
        - else
          = render "games/game_list", games: @games
