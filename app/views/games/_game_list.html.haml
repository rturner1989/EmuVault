- games.each do |game|
  - is_current = current_user.current_game_id == game.id
  %div{ class: "rounded-lg border transition-colors flex overflow-hidden bg-base-100 #{is_current ? 'border-primary' : 'border-base-300'}" }
    = render ::UI::ActionComponent.new(href: game_path(game),
      variant: :default,
      class: "flex-1 min-w-0 p-4 flex items-center justify-between gap-3 hover:bg-base-200 transition-colors",
      data: { turbo_frame: "_top" }) do
      .min-w-0
        .text-base.font-semibold.truncate
          = game.title
        .mt-1
          = render ::UI::BadgeComponent.new(color: game.system_badge_color) do
            = game.system_label
      = render ::UI::IconComponent.new(name: "fa-chevron-right", class: "text-muted shrink-0")

    .flex.items-center.border-l.border-base-300
      - if is_current
        = render ::UI::ActionComponent.new(href: current_game_path,
          method: :delete,
          variant: :default,
          title: "Clear current game",
          class: "h-full px-4 flex items-center text-primary hover:opacity-70 transition-opacity cursor-pointer",
          params: { game_id: game.id, inline: true, source: "index" }) do
          = render ::UI::IconComponent.new(name: "fa-rotate")
      - else
        = render ::UI::ActionComponent.new(href: current_game_path,
          method: :patch,
          variant: :default,
          title: "Set as current game",
          class: "h-full px-4 flex items-center text-muted hover:text-primary transition-colors cursor-pointer",
          params: { game_id: game.id, inline: true, source: "index" }) do
          = render ::UI::IconComponent.new(name: "fa-rotate")

      = render ::UI::ConfirmComponent.new(id: "remove-game-#{game.id}-dialog",
        title: "Remove game?",
        message: "Remove #{game.title} from your library? This will also delete all saved versions.",
        url: game_path(game),
        params: { source: "index" },
        trigger_label: "Remove",
        trigger_variant: :ghost,
        trigger_icon: "fa-trash-can",
        trigger_class: "text-error",
        confirm_label: "Remove")
