- games.each do |game|
  - is_current = current_user.current_game_id == game.id
  %div{ class: "rounded-lg border transition-colors flex overflow-hidden bg-base-100 #{is_current ? 'border-primary' : 'border-base-300'}" }
    = link_to game_path(game), class: "flex-1 min-w-0 p-4 flex items-center justify-between gap-3 hover:bg-base-200 transition-colors" do
      .min-w-0
        .text-base.font-semibold.truncate
          = game.title
        .mt-1
          = render ::UI::BadgeComponent.new(context_text: game.system_label, color: game.system_badge_color)
      = render ::UI::IconComponent.new(name: "fa-chevron-right", classes: "text-muted shrink-0")

    %div{ class: "border-l flex items-center border-base-300" }
      - if is_current
        = button_to current_game_path,
          method: :delete,
          params: { inline: true, source: "index" },
          title: "Clear current game",
          class: "h-full px-4 flex items-center text-primary hover:opacity-70 transition-opacity cursor-pointer" do
          = render ::UI::IconComponent.new(name: "fa-rotate")
      - else
        = button_to current_game_path,
          method: :patch,
          params: { game_id: game.id, inline: true, source: "index" },
          title: "Set as current game",
          class: "h-full px-4 flex items-center text-muted hover:text-primary transition-colors cursor-pointer" do
          = render ::UI::IconComponent.new(name: "fa-rotate")
