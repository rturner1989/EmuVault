- content_for :title, "Edit #{@game.title} — EmuVault"

.p-4.lg:p-6
  = render ::UI::PageHeaderComponent.new(title: "Edit Game")

  .rounded-lg.p-6{ class: "bg-base-100 border border-base-300" }
    = render "form", form_url: game_path(@game), submit_label: "Save Changes", cancel_path: game_path(@game)
