= render ::UI::ModalComponent.new(id: "crop-cover-dialog",
  title: "Crop Cover Image",
  container_data: { cropper_dialog: true },
  swipeable: false) do |modal|
  = modal.with_body do
    %div{ class: "overflow-hidden", style: "max-height: 70vh" }
      %img.w-full.block{ data: { cropper_image: true } }
  = modal.with_footer do
    .flex.items-center.gap-3
      %button.btn.btn-primary.btn-sm{ type: "button", data: { cropper_action: "confirm" } }
        = "Crop & Use"
      %button.btn.btn-ghost.btn-sm{ type: "button", data: { cropper_action: "cancel" } }
        = "Cancel"
