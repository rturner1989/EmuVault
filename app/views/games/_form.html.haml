= turbo_frame_tag :game_form do
  = simple_form_for @form, url: form_url, html: { id: form_id, class: "space-y-4", autocomplete: "off", data: { turbo_frame: "_top" } } do |f|
    = f.input :title,
        label: "Title",
        input_html: { class: "input input-bordered w-full" },
        label_html: { class: "label-text text-xs font-medium" }

    - allowed = (@available_systems + [@form.system.to_s]).uniq.compact
    - system_collection = allowed.any? ? Game.system.values.select { |v| allowed.include?(v.value) } : Game.system.values
    = f.input :system,
        label: "System",
        as: :select,
        collection: system_collection,
        value_method: :value,
        label_method: :text,
        include_blank: "— select a system —",
        input_html: { class: "select select-bordered w-full" },
        label_html: { class: "label-text text-xs font-medium" }

    = f.input :rom_hash,
        label: "ROM Hash (optional)",
        hint: "SHA-256 or MD5 of the ROM file — used to uniquely identify the game.",
        input_html: { class: "input input-bordered w-full font-mono" },
        label_html: { class: "label-text text-xs font-medium" },
        hint_html: { class: "mt-1 text-xs text-muted" }
