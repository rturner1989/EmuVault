= simple_form_for @form, url: form_url, html: { class: "space-y-4" } do |f|
  = f.input :title,
      label: "Title",
      input_html: { class: "input input-bordered w-full" },
      label_html: { class: "label-text text-xs font-medium" }

  = f.input :system,
      label: "System",
      as: :select,
      collection: Game.system.values,
      value_method: :value,
      label_method: :text,
      include_blank: "— select a system —",
      input_html: { class: "select select-bordered w-full" },
      label_html: { class: "label-text text-xs font-medium" }

  = f.input :rom_hash,
      label: "ROM Hash (optional)",
      hint: "SHA-256 or MD5 of the ROM file — used to uniquely identify the game.",
      input_html: { class: "input input-bordered w-full font-mono" },
      label_html: { class: "label-text text-xs font-medium" },
      hint_html: { class: "mt-1 text-xs text-drac-comment" }

  .flex.items-center.gap-3.pt-1
    %button.btn.btn-primary.btn-sm{ type: "submit" }= submit_label
    %button.btn.btn-ghost.btn-sm{ type: "button", data: { action: "dialog#close" } } Cancel
