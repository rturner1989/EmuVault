!!!
%html{ lang: "en", "data-theme": current_user&.theme || "dracula" }
  %head
    %title
      = content_for(:title) || t("layouts.application.title")
    -# Meta
    %meta{ name: "viewport", content: "width=device-width,initial-scale=1,viewport-fit=cover" }
    %meta{ name: "theme-color", content: "#282a36" }
    %meta{ name: "application-name", content: t("layouts.application.title") }
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head

    -# PWA / iOS
    %meta{ name: "apple-mobile-web-app-capable", content: "yes" }
    %meta{ name: "apple-mobile-web-app-title", content: t("layouts.application.title") }
    %meta{ name: "apple-mobile-web-app-status-bar-style", content: "black-translucent" }
    %meta{ name: "mobile-web-app-capable", content: "yes" }

    -# Icons & manifest
    %link{ rel: "icon", href: "/icon.png", type: "image/png" }
    %link{ rel: "icon", href: "/icon.svg", type: "image/svg+xml" }
    %link{ rel: "apple-touch-icon", href: "/icon.png" }
    %link{ rel: "manifest", href: "/manifest.json" }

    -# Stylesheets
    = stylesheet_link_tag "/fontawesome/css/all.min.css"
    = stylesheet_link_tag :app, "data-turbo-track": "reload"

    -# JavaScript
    = javascript_include_tag "application", "data-turbo-track": "reload", type: "module"

  %body
    = render ::Layouts::FlashComponent.new(flash: flash, position: :bottom)

    - if authenticated?
      .min-h-screen.bg-base-200{ style: "padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom)" }
        .w-full.max-w-4xl.mx-auto.min-w-0
          = yield
    - else
      = yield
