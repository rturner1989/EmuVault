- content_for :title, "Dashboard — EmuVault"

.p-4.lg:p-6.space-y-6
  = render ::UI::PageHeaderComponent.new(title: "Dashboard") do |header|
    = header.with_action do
      = render ::UI::ModalComponent.new(id: "add-game-dialog", title: "Add Game") do |modal|
        = modal.with_trigger do
          = render ::UI::ActionComponent.new(variant: :primary, id: "add-game-btn", data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
            = "Add Game"
        = modal.with_body do
          = render "games/form", form_url: games_path, form_id: "add-game-form"
        = modal.with_footer do
          = render ::UI::ActionComponent.new(variant: :primary, size: :sm, type: :submit, form: "add-game-form") do
            = "Add Game"

  = turbo_frame_tag :now_playing, class: "block space-y-4" do
    = render "shared/now_playing"

  -# Stat cards — 2×2 on mobile, 4-col on desktop
  .grid.grid-cols-2.gap-4.lg:grid-cols-4
    = turbo_frame_tag "game_stats", style: "display: contents" do
      = render "shared/game_stats", games_count: @games_count, games_without_save: @games_without_save

    = render ::UI::StatComponent.new(title: "Storage Used", value: @storage_used, description: "Save files") do |stat|
      - stat.with_icon(name: "fa-hard-drive", class: "text-info fa-lg", fw: false)

    = render ::UI::StatComponent.new(title: "Sync Events", value: @sync_events_count) do |stat|
      - stat.with_icon(name: "fa-rotate", class: "text-secondary fa-lg", fw: false)
      - stat.with_action do
        = link_to activity_path, class: "text-primary hover:underline cursor-pointer inline-flex items-center gap-1" do
          = "View all"
          %i.fa-solid.fa-arrow-right

  -# Main content — activity + insights
  .grid.grid-cols-1.gap-4.lg:grid-cols-3

    -# Recent Activity (wider)
    .lg:col-span-2
      .rounded-lg{ class: "bg-base-100 border border-base-300" }
        .px-5.py-4.flex.items-center.justify-between{ class: "border-b border-base-300" }
          %h2.text-sm.font-semibold Recent Activity
          = link_to activity_path, class: "text-xs text-primary hover:underline cursor-pointer inline-flex items-center gap-1" do
            View all
            %i.fa-solid.fa-arrow-right
        - if @recent_sync_events.empty?
          .px-5.py-8.text-center.text-sm.text-muted No activity yet.
        - else
          %ul.divide-y{ class: "divide-base-300" }
            - @recent_sync_events.each do |event|
              %li.px-5.py-3.flex.items-center.justify-between.gap-4
                .flex.items-center.gap-2
                  = render ::UI::BadgeComponent.new(color: event.action_badge_color) do |badge|
                    - badge.with_icon(name: event.action_icon)
                  = link_to event.game_title, game_path(event.game_id), class: "text-sm text-primary hover:underline truncate cursor-pointer"
                .text-xs.text-muted= event.performed_at_label

    -# Insights sidebar
    .space-y-4
      -# Top games
      .rounded-lg{ class: "bg-base-100 border border-base-300" }
        .px-5.py-4{ class: "border-b border-base-300" }
          %h2.text-sm.font-semibold Most Active Games
        - if @top_games.empty?
          .px-5.py-6.text-center.text-sm.text-muted No syncs yet.
        - else
          %ul.divide-y{ class: "divide-base-300" }
            - @top_games.each do |game|
              %li.px-5.py-3.flex.items-center.justify-between.gap-2
                = link_to game[:title], game_path(game[:id]), class: "text-sm text-primary hover:underline truncate cursor-pointer"
                .text-xs.text-muted.shrink-0= "#{game[:count]} sync#{"s" if game[:count] != 1}"

      -# Systems breakdown
      .rounded-lg{ class: "bg-base-100 border border-base-300" }
        .px-5.py-4{ class: "border-b border-base-300" }
          %h2.text-sm.font-semibold Systems
        - if @system_counts.empty?
          .px-5.py-6.text-center.text-sm.text-muted No games yet.
        - else
          %ul.divide-y{ class: "divide-base-300" }
            - @system_counts.sort_by { |_, count| -count }.each do |system, count|
              %li.px-5.py-3.flex.items-center.justify-between.gap-2
                .text-sm= system.to_s.upcase
                .text-xs.text-muted= "#{count} game#{"s" if count != 1}"
