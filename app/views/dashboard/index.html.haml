- content_for :title, "Dashboard — EmuVault"

.p-6
  = render ::UI::PageHeaderComponent.new(title: "Dashboard")

  .grid.grid-cols-1.gap-4.sm:grid-cols-3.mb-8
    .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
      .text-sm.text-drac-comment Games
      .mt-1.text-3xl.font-bold.text-drac-fg= @games_count
      .mt-2= link_to "View all →", games_path, class: "text-xs text-drac-purple hover:underline"

    .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
      .text-sm.text-drac-comment Devices
      .mt-1.text-3xl.font-bold.text-drac-fg= @devices_count
      .mt-2= link_to "View all →", devices_path, class: "text-xs text-drac-purple hover:underline"

    .rounded-lg.bg-drac-bg.border.border-drac-current.p-5
      .text-sm.text-drac-comment Emulator Profiles
      .mt-1.text-3xl.font-bold.text-drac-fg= @emulator_profiles_count
      .mt-2= link_to "View all →", emulator_profiles_path, class: "text-xs text-drac-purple hover:underline"

  .rounded-lg.bg-drac-bg.border.border-drac-current
    .px-5.py-4.border-b.border-drac-current
      %h2.text-sm.font-semibold.text-drac-fg Recent Sync Activity
    - if @recent_sync_events.empty?
      .px-5.py-8.text-center.text-sm.text-drac-comment No sync activity yet.
    - else
      %ul.divide-y.divide-drac-current
        - @recent_sync_events.each do |event|
          %li.px-5.py-3.flex.items-center.justify-between.gap-4
            .text-sm.text-drac-fg= event.game_save&.game&.title
            .text-xs.text-drac-comment= event.performed_at.strftime("%b %-d at %H:%M")
