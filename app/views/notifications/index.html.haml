= turbo_frame_tag :notifications_panel do
  - if @notifications.empty?
    .flex.flex-col.items-center.justify-center.py-12.px-4.text-center
      %i.fas.fa-bell-slash.text-3xl.text-drac-comment.mb-3
      %p.text-sm.text-drac-comment No notifications yet
  - else
    .divide-y.divide-drac-current
      - @notifications.each do |notification|
        .flex.gap-3.px-4.py-3{ class: notification.read_at ? "opacity-60" : "" }
          .flex-shrink-0.mt-0.5
            .w-8.h-8.rounded-full.bg-drac-current.flex.items-center.justify-center
              %i.fas.fa-floppy-disk.text-drac-purple.text-xs
          .flex-1.min-w-0
            %p.text-sm.text-drac-fg.leading-snug= notification.message
            %p.text-xs.text-drac-comment.mt-0.5= time_ago_in_words(notification.created_at) + " ago"
          - unless notification.read_at
            .flex-shrink-0.mt-1.5
              .w-2.h-2.rounded-full.bg-drac-purple
