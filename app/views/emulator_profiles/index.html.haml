- content_for :title, "Emulator Profiles — EmuVault"

.p-4.lg:p-6.space-y-6
  = render ::UI::PageHeaderComponent.new(title: "Emulator Profiles", subtitle: "Your configured emulators by game system")

  = render "profiles_list", selected_by_system: @selected_by_system

  -# Actions row
  .flex.items-center.justify-between.flex-wrap.gap-3
    = render ::UI::ModalComponent.new(id: "library-modal", title: "Add from library") do |modal|
      = modal.with_trigger do
        = render ::UI::ActionComponent.new(content_text: "Add from library", variant: :secondary, data: { action: "dialog#open" }) do |a|
          - a.with_leading_icon(name: "fa-plus")
      = modal.with_body do
        = turbo_frame_tag :library_modal_frame, src: library_emulator_profiles_path do
          .py-4.text-center
            %span.loading.loading-spinner.loading-sm

    = render ::UI::ModalComponent.new(id: "new-profile-dialog", title: "New Profile") do |modal|
      = modal.with_trigger do
        = render ::UI::ActionComponent.new(content_text: "Add custom profile", variant: :secondary, data: { action: "dialog#open" }) do |a|
          - a.with_leading_icon(name: "fa-plus")
      = modal.with_body do
        = render "form", profile: EmulatorProfile.new, url: emulator_profiles_path, method: :post
