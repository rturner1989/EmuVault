- if setup_incomplete?
  = render "shared/onboarding_banner",
    step: 1,
    title: "Select your emulators",
    description: "Add the emulators you use from the library or create custom profiles.",
    next_path: (games_path if EmulatorProfile.where(user_selected: true).exists?),
    next_label: "Next: Add Games"
- else
  = render ::UI::PageHeaderComponent.new(title: "Emulator Profiles", subtitle: "Your configured emulators by game system")
