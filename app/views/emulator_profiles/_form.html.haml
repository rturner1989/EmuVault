= turbo_frame_tag dom_id(profile, :form) do
  = simple_form_for profile, url: url, method: method, html: { class: "space-y-4", autocomplete: "off", data: { turbo_frame: "_top" } } do |f|
    = f.input :name, label: "Emulator name", input_html: { class: "input input-bordered w-full" }
    = f.input :platform, collection: EmulatorProfile.platform.values, label_method: :text, value_method: :value, include_blank: "Select platform", label: "Platform", input_html: { class: "select select-bordered w-full" }
    = f.input :game_system, collection: EmulatorProfile.game_system.values, label_method: :text, value_method: :value, include_blank: "Select game system", label: "Game system", hint: "Required for library scanning", input_html: { class: "select select-bordered w-full" }
    = f.input :save_extension, label: "Save extension (without dot)", placeholder: "e.g. srm", input_html: { class: "input input-bordered w-full" }
    = f.input :default_save_path, label: "Save directory", placeholder: "e.g. /games/retroarch/saves/gba/", hint: "Path inside the container — mount your saves directory as a volume", input_html: { class: "input input-bordered w-full font-mono" }
    .pt-2
      = f.submit "Save", class: "btn btn-primary w-full"
