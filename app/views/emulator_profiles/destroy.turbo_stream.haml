= turbo_stream.action :close_dialog, "delete-profile-#{@profile.id}"
- if @destroy_failed
  - @alert_text = @destroy_error == :in_use ? "Can't remove — you have games for this system. Remove those games first." : "Could not remove profile."
- else
  = turbo_stream.replace "profiles_list", partial: "emulator_profiles/profiles_list", locals: { selected_by_system: @selected_by_system }
  = turbo_stream.update "page_header", partial: "emulator_profiles/page_header"
  = turbo_stream.update "onboarding-banner" do
    = render "shared/onboarding_banner",
      step: 1,
      title: "Select your emulators",
      description: "Add the emulators you use from the library or create custom profiles.",
      next_path: (onboarding_games_path if EmulatorProfile.where(user_selected: true).exists?),
      next_label: "Next: Add Games"

- flash_type = @notice_text ? :notice : :alert
- flash_message = @notice_text || @alert_text
= turbo_stream.append "flash-container", ::Layouts::FlashComponent::Item.new(type: flash_type, message: flash_message)
