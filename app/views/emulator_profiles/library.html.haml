= turbo_frame_tag :library_modal_frame do
  - if @systems.any?
    = form_with url: library_system_emulator_profiles_path, method: :get, data: { turbo_frame: :library_modal_frame } do |f|
      %p.text-sm.text-muted.mb-3 Select the systems you want to add emulators for.
      .grid.gap-2.mb-4{ style: "grid-template-columns: repeat(auto-fill, minmax(120px, 1fr))" }
        - @systems.each do |system|
          - already_has = @selected_systems.include?(system.value.to_sym)
          %label{ class: "flex flex-col items-center gap-1.5 px-3 py-4 rounded-lg border text-center cursor-pointer transition-all border-base-300 #{ already_has ? 'opacity-50' : 'hover:border-primary hover:bg-base-200 has-[:checked]:border-primary has-[:checked]:bg-base-200' }" }
            %input{ type: "checkbox", name: "systems[]", value: system.value, class: "peer sr-only", disabled: already_has }
            %span.text-sm.font-medium= system.text
            - if already_has
              %span.text-xs.text-muted Already added
            - else
              %i.fa-solid.fa-check.text-xs.text-primary{ class: "invisible peer-checked:visible" }
      %button.btn.btn-primary.w-full{ type: "submit" }
        Next
        %i.fa-solid.fa-arrow-right
  - else
    %p.text-sm.text-muted All available emulators from the library are already added.
