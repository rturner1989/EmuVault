= turbo_frame_tag :library_modal_frame do
  .space-y-4
    %p.text-sm.text-muted Which system do you want to add emulators for?

    - if @systems.any?
      .grid.gap-2{ style: "grid-template-columns: repeat(auto-fill, minmax(120px, 1fr))" }
        - @systems.each do |system|
          - already_has = @selected_systems.include?(system.value.to_sym)
          = link_to library_system_emulator_profiles_path(system: system.value),
              data: { turbo_frame: :library_modal_frame },
              class: "flex flex-col items-center gap-1.5 px-3 py-4 rounded-lg border text-center transition-colors #{ already_has ? 'border-base-300 opacity-50' : 'border-base-300 hover:border-primary hover:bg-base-200 cursor-pointer' }" do
            %span.text-sm.font-medium= system.text
            - if already_has
              %span.text-xs.text-muted Already added
    - else
      %p.text-sm.text-muted All available emulators from the library are already added.
