.flex.items-center.gap-3.mb-4
  = render ::UI::ActionComponent.new(href: emulator_profiles_library_index_path,
    variant: :default,
    class: "text-muted hover:text-base-content transition-colors",
    data: { turbo_frame: :library_modal_frame }) do |a|
    - a.with_leading_icon(name: "fa-arrow-left")
  %p.text-sm.font-semibold
    = @system_label

  - if @total > 1
    %span.text-xs.text-muted
      = "(#{@current_pos}/#{@total})"

- is_last = @remaining.empty?
- if @profiles.any?
  = form_with url: emulator_profiles_library_index_path, method: :post, id: "library-step-form" do |f|
    %input{ type: "hidden", name: "total", value: @total }

    - @remaining.each do |sys|
      %input{ type: "hidden", name: "remaining[]", value: sys }

    .space-y-2
      - @profiles.each do |profile|
        %label{ class: "flex items-center gap-3 px-3 py-2.5 rounded-lg border cursor-pointer border-base-300 hover:border-primary hover:bg-base-200 transition-colors" }
          %input.accent-primary{ type: "checkbox", name: "profile_ids[]", value: profile.id }
          .flex-1.min-w-0
            %p.text-sm.font-medium
              = profile.name
            = render ::UI::BadgeComponent.new(color: platform_badge_color(profile.platform)) do
              = profile.platform_label
          %span.text-xs.text-muted.font-mono.shrink-0
            = ".#{profile.save_extension}"
    .sticky.bottom-0.pt-3.mt-4.border-t.border-base-300.bg-base-100
      = render ::UI::ActionComponent.new(variant: :primary,
        size: :sm,
        type: :submit) do |a|
        - a.with_trailing_icon(name: is_last ? "fa-check" : "fa-arrow-right")
        = is_last ? "Confirm" : "Next"
- else
  %p.text-sm.text-muted
    = "All emulators for this system are already added."
  - if @remaining.any?
    = form_with url: emulator_profiles_library_index_path(system: @remaining.first, remaining: @remaining.drop(1), total: @total),
      method: :get,
      id: "library-step-form",
      data: { turbo_frame: :library_modal_frame } do |f|
      .sticky.bottom-0.pt-3.mt-4.border-t.border-base-300.bg-base-100
        = render ::UI::ActionComponent.new(variant: :primary,
          size: :sm,
          type: :submit) do |a|
          - a.with_trailing_icon(name: is_last ? "fa-check" : "fa-arrow-right")
          = is_last ? "Confirm" : "Next"
  - else
    = form_with url: emulator_profiles_library_index_path,
      method: :post,
      id: "library-step-form" do |f|
      .sticky.bottom-0.pt-3.mt-4.border-t.border-base-300.bg-base-100
        = render ::UI::ActionComponent.new(variant: :primary,
          size: :sm,
          type: :submit) do |a|
          - a.with_trailing_icon(name: "fa-check")
          = "Confirm"
