- if @previous.any?
  - back_path = emulator_profiles_library_index_path(system: @previous.last, remaining: [@system] + @remaining, previous: @previous[0..-2], total: @total)
- else
  - back_path = emulator_profiles_library_index_path
.flex.items-center.gap-3.mb-4
  = render ::UI::ActionComponent.new(href: back_path,
    variant: :default,
    class: "text-muted hover:text-base-content transition-colors",
    data: { turbo_frame: :library_modal_frame }) do |a|
    - a.with_leading_icon(name: "fa-arrow-left")
  %p.text-sm.font-semibold
    = @system_label

  - if @total > 1
    %span.text-xs.text-muted
      = "(#{@current_pos}/#{@total})"

= form_with url: emulator_profiles_library_index_path, method: :post, id: "library-step-form" do |f|
  %input{ type: "hidden", name: "game_system", value: @system }
  %input{ type: "hidden", name: "total", value: @total }

  - @remaining.each do |sys|
    %input{ type: "hidden", name: "remaining[]", value: sys }

  - @previous.each do |sys|
    %input{ type: "hidden", name: "previous[]", value: sys }

  .space-y-2
    - @profiles.each do |profile|
      - selected = @selected_ids.include?(profile.id)
      - locked = @system_in_use && selected
      %label{ class: "flex items-center gap-3 px-3 py-2.5 rounded-lg border transition-colors #{locked ? 'border-primary bg-base-200 cursor-not-allowed opacity-60' : selected ? 'border-primary bg-base-200 cursor-pointer' : 'border-base-300 hover:border-primary hover:bg-base-200 cursor-pointer'}",
        title: (locked ? "Games exist for this system" : nil) }
        - if locked
          %input{ type: "hidden", name: "profile_ids[]", value: profile.id }
        %input.accent-primary{ type: "checkbox", name: "profile_ids[]", value: profile.id, checked: selected, disabled: locked }
        .flex-1.min-w-0
          %p.text-sm.font-medium
            = profile.name
          = render ::UI::BadgeComponent.new(color: platform_badge_color(profile.platform)) do
            = profile.platform_label
        %span.text-xs.text-muted.font-mono.shrink-0
          = ".#{profile.save_extension}"
