= turbo_frame_tag "profiles_list" do
  - if selected_by_system.any?
    %div{ data: { controller: "profile-select" } }
      = form_with url: emulator_profiles_bulk_destroy_path,
        method: :post,
        data: { profile_select_target: "bulkForm" } do |f|
        -# Hidden inputs are populated by Stimulus before submit — no static inputs here

      -# Bulk action bar
      %div{ class: "hidden mb-3 flex items-center gap-3 rounded-lg px-4 py-3 bg-base-200 border border-base-300", data: { profile_select_target: "bulkBar" } }
        %input.checkbox.checkbox-primary.checkbox-sm{ type: "checkbox", data: { profile_select_target: "selectAll", action: "change->profile-select#toggleAll" } }
        %span.text-sm.text-muted{ data: { profile_select_target: "count" } }
        .flex.items-center.gap-2.ml-auto
          = render ::UI::ActionComponent.new(variant: :ghost,
            size: :xs,
            data: { action: "profile-select#clearSelection" }) do
            = "Deselect all"
          = render ::UI::ActionComponent.new(variant: :danger,
            size: :xs,
            type: :button,
            data: { action: "profile-select#submitBulk" }) do |a|
            - a.with_leading_icon(name: "fa-trash-can")
            = "Delete selected"

      - in_use_systems = Game.distinct.pluck(:system).map(&:to_sym).to_set
      .space-y-4
        - selected_by_system.each do |system_key, profiles|
          - system_label = system_key.present? ? EmulatorProfile.game_system_label(system_key) : "Unknown System"
          = render ::UI::CardComponent.new(padding: :sm) do |c|
            - c.with_header do
              %span.font-medium.text-sm
                = system_label

            .divide-y.divide-base-300
              - profiles.each do |profile|
                - profile_in_use = in_use_systems.include?(profile.game_system&.to_sym)
                .flex.items-center.gap-3.px-4.py-3
                  %input{ type: "checkbox",
                    class: "checkbox checkbox-primary checkbox-sm shrink-0 #{"cursor-not-allowed opacity-60" if profile_in_use}",
                    value: profile.id,
                    disabled: profile_in_use,
                    title: profile_in_use ? "Can't select — games exist for this system" : nil,
                    data: { profile_select_target: "checkbox", action: "change->profile-select#toggle" } }
                  .flex-1.min-w-0
                    .flex.items-center.gap-2.mb-1
                      %span.text-sm.font-medium
                        = profile.name
                      = render ::UI::BadgeComponent.new(color: platform_badge_color(profile.platform)) do
                        = profile.platform_label
                      %span.text-xs.text-muted.font-mono
                        = ".#{profile.save_extension}"
                    - if profile.default_save_path.present?
                      %p.text-xs.text-muted.font-mono.truncate
                        = profile.default_save_path
                    - else
                      %p.text-xs.text-muted
                        = "No save path set"
                  .flex.items-center.gap-2.shrink-0
                    = render ::UI::ModalComponent.new(id: "edit-profile-#{profile.id}", title: "Edit Profile") do |modal|
                      = modal.with_trigger do
                        = render ::UI::ActionComponent.new(variant: :secondary,
                          size: :xs,
                          data: { action: "dialog#open" }) do
                          = "Edit"
                      = modal.with_body do
                        = render "emulator_profiles/form", profile: profile,
                          url: emulator_profile_path(profile),
                          method: :patch,
                          form_id: "edit-profile-#{profile.id}-form"
                      = modal.with_footer do
                        = render ::UI::ActionComponent.new(variant: :primary,
                          size: :sm,
                          type: :submit,
                          form: "edit-profile-#{profile.id}-form") do
                          = "Save"
                    - if profile_in_use
                      = render ::UI::ActionComponent.new(variant: :danger,
                        size: :xs,
                        disabled: true,
                        title: "Remove all #{system_label} games first") do
                        = "Remove"
                    - else
                      = render ::UI::ConfirmComponent.new(id: "delete-profile-#{profile.id}",
                        title: profile.is_default ? "Remove profile?" : "Delete profile?",
                        message: profile.is_default ? "Remove this profile from your list? You can add it back later." : "Delete this profile permanently?",
                        url: emulator_profile_path(profile),
                        method: :delete,
                        trigger_label: "Remove",
                        size: :xs)
  - else
    = render ::UI::EmptyStateComponent.new(title: "No emulators configured yet", description: "Add emulators from the library or create a custom profile.") do |c|
      - c.with_action do
        .flex.items-center.gap-3.flex-wrap.justify-center
          = render ::UI::ActionComponent.new(variant: :primary, data: { "a11y-dialog-show": "library-modal" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
            = "Add from library"
          = render ::UI::ActionComponent.new(variant: :secondary, data: { "a11y-dialog-show": "new-profile-dialog" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
            = "Add custom profile"

  -# Actions row and modal containers
  - if selected_by_system.any?
    .flex.items-center.gap-3.flex-wrap.mt-2
      = render ::UI::ModalComponent.new(id: "library-modal",
        title: "Add from library",
        subtitle: "Select the systems you want to add emulators for.") do |modal|
        = modal.with_trigger do
          = render ::UI::ActionComponent.new(variant: :secondary, data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
            = "Add from library"
        = modal.with_body do
          = turbo_frame_tag :library_modal_frame, src: emulator_profiles_library_index_path do
            .py-4.text-center
              %span.loading.loading-spinner.loading-sm
        = modal.with_footer do
          = turbo_frame_tag "library-next-btn" do
            = render "emulator_profiles/library_next_btn", is_last: false
      = render ::UI::ModalComponent.new(id: "new-profile-dialog", title: "New Profile") do |modal|
        = modal.with_trigger do
          = render ::UI::ActionComponent.new(variant: :secondary, data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
            = "Add custom profile"
        = modal.with_body do
          = render "emulator_profiles/form", profile: EmulatorProfile.new,
            url: emulator_profiles_path,
            method: :post,
            form_id: "new-profile-form"
        = modal.with_footer do
          = render ::UI::ActionComponent.new(variant: :primary,
            size: :sm,
            type: :submit,
            form: "new-profile-form") do
            = "Save"
  - else
    -# Render modal containers without triggers so a11y-dialog-show works from the empty state
    = render ::UI::ModalComponent.new(id: "library-modal",
      title: "Add from library",
      subtitle: "Select the systems you want to add emulators for.") do |modal|
      = modal.with_body do
        = turbo_frame_tag :library_modal_frame, src: emulator_profiles_library_index_path do
          .py-4.text-center
            %span.loading.loading-spinner.loading-sm
      = modal.with_footer do
        = render ::UI::ActionComponent.new(variant: :primary,
          size: :sm,
          type: :submit,
          form: "library-step-form",
          data: { turbo_frame: "library_modal_frame" }) do |a|
          - a.with_trailing_icon(name: "fa-arrow-right")
          = "Next"
    = render ::UI::ModalComponent.new(id: "new-profile-dialog",
      title: "New Profile") do |modal|
      = modal.with_body do
        = render "emulator_profiles/form", profile: EmulatorProfile.new,
          url: emulator_profiles_path,
          method: :post,
          form_id: "new-profile-form"
      = modal.with_footer do
        = render ::UI::ActionComponent.new(variant: :primary,
          size: :sm,
          type: :submit,
          form: "new-profile-form") do
          = "Save"
