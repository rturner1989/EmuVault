= turbo_frame_tag "profiles_list" do
  - if selected_by_system.any?
    - in_use_systems = Game.distinct.pluck(:system).map(&:to_sym).to_set
    %div{ data: { controller: "profile-select" } }
      -# Bulk form — separate from profile cards to avoid nested forms
      = form_with url: bulk_destroy_emulator_profiles_path, method: :delete, data: { profile_select_target: "bulkForm" } do |f|
        -# Hidden inputs are populated by Stimulus before submit — no static inputs here

      -# Bulk action bar — hidden until checkboxes selected
      %div{ class: "hidden mb-3 flex items-center gap-3 rounded-lg px-4 py-3 bg-base-200 border border-base-300", data: { profile_select_target: "bulkBar" } }
        %input.checkbox.checkbox-primary.checkbox-sm{ type: "checkbox", data: { profile_select_target: "selectAll", action: "change->profile-select#toggleAll" } }
        %span.text-sm.text-muted{ data: { profile_select_target: "count" } }
        .flex.items-center.gap-2.ml-auto
          = render ::UI::ActionComponent.new(content_text: "Deselect all", variant: :ghost, size: :xs, data: { action: "profile-select#clearSelection" })
          %button.btn.btn-error.btn-xs{ type: "button", data: { action: "profile-select#submitBulk" } }
            %i.fa-solid.fa-trash-can.mr-1
            = "Delete selected"

      .space-y-4
        - selected_by_system.each do |system_key, profiles|
          - system_label = EmulatorProfile.game_system.find_value(system_key)&.text || (system_key.present? ? system_key.to_s.upcase : "Unknown System")
          = render ::UI::CardComponent.new(padding: :sm) do |c|
            - c.with_header do
              %span.font-medium.text-sm= system_label

            %div{ class: "divide-y divide-base-300" }
              - profiles.each do |profile|
                .flex.items-center.gap-3.px-4.py-3
                  - profile_in_use = in_use_systems.include?(profile.game_system&.to_sym)
                  %input.checkbox.checkbox-primary.checkbox-sm.shrink-0{ type: "checkbox", value: profile.id, disabled: profile_in_use, class: profile_in_use ? "cursor-not-allowed" : nil, title: profile_in_use ? "Can't select — games exist for this system" : nil, data: { profile_select_target: "checkbox", action: "change->profile-select#toggle" } }
                  .flex-1.min-w-0
                    .flex.items-center.gap-2.mb-1
                      %span.text-sm.font-medium= profile.name
                      = render ::UI::BadgeComponent.new(context_text: profile.platform.text, color: platform_badge_color(profile.platform))
                      %span.text-xs.text-muted.font-mono .#{profile.save_extension}
                    - if profile.default_save_path.present?
                      %p.text-xs.text-muted.font-mono.truncate= profile.default_save_path
                    - else
                      %p.text-xs.text-muted No save path set
                  .flex.items-center.gap-2.shrink-0
                    = render ::UI::ModalComponent.new(id: "edit-profile-#{profile.id}", title: "Edit Profile") do |modal|
                      = modal.with_trigger do
                        = render ::UI::ActionComponent.new(content_text: "Edit", variant: :secondary, size: :xs, data: { action: "dialog#open" })
                      = modal.with_body do
                        = render "form", profile: profile, url: emulator_profile_path(profile), method: :patch, form_id: "edit-profile-#{profile.id}-form"
                      = modal.with_footer do
                        = render ::UI::ActionComponent.new(content_text: "Save", variant: :primary, size: :sm, type: :submit, form: "edit-profile-#{profile.id}-form")
                    - if in_use_systems.include?(profile.game_system&.to_sym)
                      - system_label = EmulatorProfile.game_system.find_value(profile.game_system)&.text || profile.game_system.to_s.upcase
                      = render ::UI::ActionComponent.new(content_text: "Remove", variant: :danger, size: :xs, disabled: true, title: "Remove all #{system_label} games first")
                    - else
                      = render ::UI::ConfirmComponent.new(id: "delete-profile-#{profile.id}",
                        title: profile.is_default ? "Remove profile?" : "Delete profile?",
                        message: profile.is_default ? "Remove this profile from your list? You can add it back later." : "Delete this profile permanently?",
                        url: emulator_profile_path(profile),
                        method: :delete,
                        trigger_label: "Remove",
                        size: :xs)
  - else
    = render ::UI::EmptyStateComponent.new(title: "No emulators configured yet", description: "Add emulators from the library or create a custom profile.") do |c|
      - c.with_action do
        .flex.items-center.gap-3.flex-wrap.justify-center
          = render ::UI::ActionComponent.new(content_text: "Add from library", variant: :primary, data: { "a11y-dialog-show": "library-modal" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
          = render ::UI::ActionComponent.new(content_text: "Add custom profile", variant: :secondary, data: { "a11y-dialog-show": "new-profile-dialog" }) do |a|
            - a.with_leading_icon(name: "fa-plus")

  -# Actions row and modal containers — inside the frame so turbo_stream updates keep them in sync
  - if selected_by_system.any?
    .flex.items-center.gap-3.flex-wrap.mt-2
      = render ::UI::ModalComponent.new(id: "library-modal", title: "Add from library", subtitle: "Select the systems you want to add emulators for.") do |modal|
        = modal.with_trigger do
          = render ::UI::ActionComponent.new(content_text: "Add from library", variant: :secondary, data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
        = modal.with_body do
          = turbo_frame_tag :library_modal_frame, src: library_emulator_profiles_path do
            .py-4.text-center
              %span.loading.loading-spinner.loading-sm
        = modal.with_footer do
          = turbo_frame_tag "library-next-btn" do
            = render "library_next_btn", is_last: false
      = render ::UI::ModalComponent.new(id: "new-profile-dialog", title: "New Profile") do |modal|
        = modal.with_trigger do
          = render ::UI::ActionComponent.new(content_text: "Add custom profile", variant: :secondary, data: { action: "dialog#open" }) do |a|
            - a.with_leading_icon(name: "fa-plus")
        = modal.with_body do
          = render "form", profile: EmulatorProfile.new, url: emulator_profiles_path, method: :post, form_id: "new-profile-form"
        = modal.with_footer do
          = render ::UI::ActionComponent.new(content_text: "Save", variant: :primary, size: :sm, type: :submit, form: "new-profile-form")
  - else
    -# Render modal containers without triggers so a11y-dialog-show works from the empty state
    = render ::UI::ModalComponent.new(id: "library-modal", title: "Add from library", subtitle: "Select the systems you want to add emulators for.") do |modal|
      = modal.with_body do
        = turbo_frame_tag :library_modal_frame, src: library_emulator_profiles_path do
          .py-4.text-center
            %span.loading.loading-spinner.loading-sm
      = modal.with_footer do
        = render ::UI::ActionComponent.new(content_text: "Next", variant: :primary, size: :sm, type: :submit, form: "library-step-form", data: { turbo_frame: "library_modal_frame" }) do |a|
          - a.with_trailing_icon(name: "fa-arrow-right")
    = render ::UI::ModalComponent.new(id: "new-profile-dialog", title: "New Profile") do |modal|
      = modal.with_body do
        = render "form", profile: EmulatorProfile.new, url: emulator_profiles_path, method: :post, form_id: "new-profile-form"
      = modal.with_footer do
        = render ::UI::ActionComponent.new(content_text: "Save", variant: :primary, size: :sm, type: :submit, form: "new-profile-form")
