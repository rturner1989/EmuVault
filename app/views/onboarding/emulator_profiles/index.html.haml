- content_for :title, "Select Emulators — EmuVault"

.p-4.space-y-6
  = turbo_frame_tag "onboarding-banner", style: "display: contents" do
    = render "shared/onboarding_banner",
      step: 1,
      title: "Select your emulators",
      description: "Add the emulators you use from the library or create custom profiles.",
      next_path: (onboarding_games_path if EmulatorProfile.where(user_selected: true).exists?),
      next_label: "Next: Add Games"

  = turbo_frame_tag "page_header", style: "display: contents"

  = render "emulator_profiles/profiles_list", selected_by_system: @selected_by_system
