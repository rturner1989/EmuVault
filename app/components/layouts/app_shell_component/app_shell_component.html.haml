= helpers.turbo_stream_from "notifications_#{Current.user.id}"

.flex.min-h-screen.bg-drac-surface{ data: { controller: "notifications" } }
  %nav.hidden.lg:flex.lg:flex-col.lg:w-64.lg:fixed.lg:inset-y-0.bg-drac-bg.border-r.border-drac-current
    .flex.items-center.h-16.px-6.border-b.border-drac-current
      = link_to root_path, class: "text-xl font-bold text-drac-purple hover:opacity-80 transition-opacity" do
        EmuVault

    .flex-1.overflow-y-auto.px-3.py-4.space-y-1
      = link_to root_path, class: nav_link_class("/") do
        %span Dashboard
      = link_to games_path, class: nav_link_class("/games") do
        %span Games
      = link_to activity_path, class: nav_link_class("/activity") do
        %span Activity
      = link_to emulator_profiles_path, class: nav_link_class("/emulator_profiles") do
        %span Emulator Profiles

    .border-t.border-drac-current.p-3.space-y-1
      .px-3.py-1.text-xs.text-drac-comment.truncate= Current.user.email_address
      %button.flex.items-center.justify-between.w-full.px-3.py-2.rounded-lg.text-sm.text-drac-comment.hover:bg-drac-current.hover:text-drac-fg.transition-colors.cursor-pointer{ data: { action: "notifications#open" } }
        %span Notifications
        .relative.inline-flex.items-center.justify-center.w-6.h-6
          %i.fas.fa-bell
          = render "shared/notification_badge", count: unread_count
      = link_to settings_path, class: "flex items-center px-3 py-2 rounded-lg text-sm text-drac-comment hover:bg-drac-current hover:text-drac-fg transition-colors" do
        %span Settings
      = button_to session_path, method: :delete, form: { data: { turbo: false } }, class: "w-full flex items-center px-3 py-2 rounded-lg text-sm text-drac-comment hover:bg-drac-current hover:text-drac-red transition-colors" do
        %span Sign Out

  .lg:pl-64.flex-1.flex.flex-col.min-h-screen.mobile-bottom-content-pad.lg:pt-0.lg:pb-0
    .lg:hidden.flex.items-center.px-4.pb-2.bg-drac-bg.border-b.border-drac-current.mobile-top-bar
      = link_to root_path, class: "text-lg font-bold text-drac-purple hover:opacity-80 transition-opacity" do
        EmuVault
      .ml-auto
        %button.relative.inline-flex.items-center.justify-center.w-8.h-8.text-drac-comment.hover:text-drac-fg.transition-colors.cursor-pointer{ data: { action: "notifications#open" } }
          %i.fas.fa-bell
          = render "shared/notification_badge", count: unread_count

    .w-full.max-w-4xl.mx-auto
      = content_body

  %nav.fixed.bottom-0.left-0.right-0.z-50.lg:hidden.bg-drac-bg.border-t.border-drac-current.mobile-bottom-nav
    .flex
      = link_to root_path, class: mobile_nav_class("/") do
        %span Dashboard
      = link_to games_path, class: mobile_nav_class("/games") do
        %span Games
      = link_to activity_path, class: mobile_nav_class("/activity") do
        %span Activity
      = link_to emulator_profiles_path, class: mobile_nav_class("/emulator_profiles") do
        %span Profiles
      = link_to settings_path, class: mobile_nav_class("/settings") do
        %span Settings

  -# Notification panel overlay
  %div{ data: { notifications_target: "backdrop" }, class: "fixed inset-0 z-50 pointer-events-none" }
    %div.absolute.inset-0.opacity-0.transition-opacity.duration-300{ class: "bg-black/40", data: { notifications_target: "overlay", action: "click->notifications#close" } }
    .absolute.right-0.top-0.h-full.w-full.lg:max-w-sm.bg-drac-bg.border-l.border-drac-current.flex.flex-col.translate-x-full.transition-transform.duration-300.ease-out{ data: { notifications_target: "panel" } }
      .flex.items-center.justify-between.px-4.py-3.border-b.border-drac-current.notification-panel-top
        %h2.font-semibold.text-drac-fg Notifications
        %button.text-drac-comment.hover:text-drac-fg.transition-colors.cursor-pointer.p-1{ data: { action: "click->notifications#close" } }
          %i.fas.fa-times
      .flex-1.overflow-y-auto
        = helpers.turbo_frame_tag :notifications_panel, src: notifications_path, loading: :lazy, data: { notifications_target: "frame" }
      .px-4.py-2.border-t.border-drac-current.notification-panel-bottom
        %button.text-xs.text-drac-comment.hover:text-drac-fg.transition-colors.cursor-pointer.w-full.text-left.py-1{ data: { action: "click->notifications#markAllRead" } }
          Mark all as read
