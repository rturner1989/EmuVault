%div{ class: "stat bg-base-100 border border-base-300 rounded-lg" }
  %div{ class: "stat-title flex items-center gap-1.5" }
    - if icon?
      = icon
    = @title
  %div{ class: "stat-value text-2xl #{@value_color}" }
    = @value
  - if @description || action?
    %div{ class: "stat-desc" }
      - if action?
        = action
      - else
        = @description
