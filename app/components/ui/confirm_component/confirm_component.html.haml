= render ::UI::ModalComponent.new(id: @id, title: @title) do |modal|
  = modal.with_trigger do
    = render ::UI::ActionComponent.new(content_text: @trigger_label, variant: :danger, size: @size, data: { action: "dialog#open" })
  = modal.with_body do
    %p.text-sm.opacity-70.mb-5= @message
    .flex.items-center.gap-3
      = button_to @confirm_label, @url, method: @method, class: "btn btn-error btn-sm"
      %button.btn.btn-ghost.btn-sm{ type: "button", data: { action: "dialog#close" } } Cancel
