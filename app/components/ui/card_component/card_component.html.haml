%div{ class: @class, **@kwargs }
  - if header?
    %div{ class: "shrink-0 #{padding_class}" }
      = header

  - if body?
    %div{ class: body_class }
      = body
  - elsif content_class
    %div{ class: content_class }
      = content
  - else
    = content

  - if footer?
    %div{ class: "shrink-0 #{padding_class}" }
      = footer
  - elsif footer_actions?
    %div{ class: "shrink-0 flex gap-3 #{padding_class}" }
      - footer_actions.each do |action|
        = action
